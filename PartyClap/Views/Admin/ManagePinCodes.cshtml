@model IEnumerable<PartyClap.Models.AllowedPinCode>
@{
    ViewData["Title"] = "Manage Serviceable PIN Codes";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="fw-bold mb-0">Manage Serviceable PIN Codes</h1>
            <p class="text-muted">Only vendors in these areas will be shown to customers.</p>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-2"></i> Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Add New Area</h5>
                    <form asp-action="AddPinCode" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">PIN Code</label>
                            <input type="text" name="pinCode" class="form-control rounded-3" placeholder="e.g., 400001" required pattern="[0-9]{6}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Area/City Name</label>
                            <input type="text" name="cityName" class="form-control rounded-3" placeholder="e.g., Mumbai - Fort" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
                            <i class="bi bi-plus-circle me-1"></i> Allow Area
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Serviceable Areas (@(Model?.Count() ?? 0))</h5>
                    @if (Model == null || !Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-geo-alt text-muted display-4"></i>
                            <p class="mt-3 text-muted">No areas have been restricted yet. Currently all areas might be searchable.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>PIN Code</th>
                                        <th>Area Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td><code class="fw-bold text-primary">@item.PinCode</code></td>
                                            <td>@item.CityName</td>
                                            <td class="text-end">
                                                <form asp-action="DeletePinCode" method="post">
                                                    <input type="hidden" name="pinCode" value="@item.PinCode" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Remove">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
