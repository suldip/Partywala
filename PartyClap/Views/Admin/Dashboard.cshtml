@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Admin Dashboard</h2>
    
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Vendors</h5>
                    <p class="display-4">@ViewBag.TotalVendors</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Bookings</h5>
                    <p class="display-4">@ViewBag.TotalBookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Revenue</h5>
                    <p class="display-4">₹@ViewBag.TotalRevenue</p>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Pending Approvals</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">No pending vendor approvals.</p>
        </div>
    </div>
</div>
