@{
    ViewData["Title"] = "Platform Settings";
    Layout = "_Layout";
    var feePercent = ViewBag.PlatformFeePercent != null ? (decimal)ViewBag.PlatformFeePercent : 10m;
}

<div class="container py-5">
    <div class="row mb-4 align-items-center g-3">
        <div class="col">
            <h1 class="fw-bold mb-1">Platform Settings</h1>
            <p class="text-muted mb-0">
                Configure platform-wide business rules. Changes apply to all new price calculations
                immediately &mdash; no redeploy required.
            </p>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left me-1"></i> Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3"
                             style="width:48px;height:48px;background:linear-gradient(135deg,#7c3aed,#ec4899);color:#fff;">
                            <i class="bi bi-cash-coin fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Platform Fee</h5>
                            <small class="text-muted">Markup added on top of the vendor's base cost</small>
                        </div>
                    </div>

                    <form method="post" asp-action="Settings">
                        @Html.AntiForgeryToken()
                        <label for="platformFeePercent" class="form-label fw-semibold">Fee percentage</label>
                        <div class="input-group input-group-lg mb-2" style="max-width:240px;">
                            <input type="number" step="0.5" min="0" max="100" required
                                   class="form-control text-end" id="platformFeePercent"
                                   name="platformFeePercent" value="@feePercent" />
                            <span class="input-group-text">%</span>
                        </div>
                        <div class="form-text mb-4">
                            Allowed range: 0&ndash;100%. Customers are charged
                            <strong>base cost + this fee</strong>.
                        </div>
                        <button type="submit" class="btn btn-lg rounded-pill px-4"
                                style="background:linear-gradient(135deg,#7c3aed,#ec4899);color:#fff;">
                            <i class="bi bi-save me-1"></i> Save changes
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3">Live example</h6>
                    <p class="text-muted small mb-3">Based on a sample vendor base cost of &#8377;10,000.</p>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>Vendor base cost</span>
                        <span class="fw-semibold">&#8377;10,000</span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>Platform fee (@feePercent%)</span>
                        <span class="fw-semibold" id="exampleFee">&#8377;@((10000m * feePercent / 100m).ToString("N0"))</span>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span class="fw-bold">Customer pays</span>
                        <span class="fw-bold text-success" id="exampleTotal">&#8377;@((10000m * (1m + feePercent / 100m)).ToString("N0"))</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('platformFeePercent');
            var feeEl = document.getElementById('exampleFee');
            var totalEl = document.getElementById('exampleTotal');
            function fmt(n) { return '\u20B9' + Math.round(n).toLocaleString('en-IN'); }
            function update() {
                var pct = parseFloat(input.value);
                if (isNaN(pct) || pct < 0) pct = 0;
                feeEl.textContent = fmt(10000 * pct / 100);
                totalEl.textContent = fmt(10000 * (1 + pct / 100));
            }
            if (input) input.addEventListener('input', update);
        })();
    </script>
}
