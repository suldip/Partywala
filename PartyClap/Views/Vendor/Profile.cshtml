@model PartyClap.Models.Vendor
@{
    ViewData["Title"] = "Vendor Profile";
    Layout = "_Layout";
}

<div class="container py-4">
    <partial name="_VendorMenu" />
    
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary-gradient p-4 text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold">Edit Profile</h4>
                        <a asp-action="Dashboard" class="btn btn-outline-light btn-sm rounded-pill px-3">
                            Back to Dashboard
                        </a>
                    </div>
                </div>
                <div class="card-body p-5 bg-light">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4">
                            <div class="d-flex align-items-center">
                                <span class="me-2">✅</span>
                                <div>@TempData["SuccessMessage"]</div>
                            </div>
                        </div>
                    }

                    <form asp-action="Profile" method="post">
                        @Html.HiddenFor(m => m.Id)
                        @Html.HiddenFor(m => m.IsRegistered)
                        @Html.HiddenFor(m => m.TrustScore)
                        @Html.HiddenFor(m => m.WalletBalance)

                        <!-- Profile Header Info -->
                        <div class="d-flex align-items-center mb-5 pb-4 border-bottom">
                            <div class="bg-white p-3 rounded-circle shadow-sm me-4">
                                <div class="avatar-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center rounded-circle" style="width: 64px; height: 64px; font-size: 24px; font-weight: bold;">
                                    @(Model.Name?.Substring(0, 1).ToUpper() ?? "V")
                                </div>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-1">@Model.Name</h5>
                                <div class="d-flex gap-3 text-muted small">
                                    <span>⭐ Trust Score: @Model.TrustScore</span>
                                    <span>💰 Wallet: ₹@Model.WalletBalance.ToString("N2")</span>
                                    <span>@(Model.IsRegistered ? "✅ Verified" : "⏳ Pending")</span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold text-dark">Full Name</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Enter your business name" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold text-dark">Email Address</label>
                                <input asp-for="Email" class="form-control form-control-lg rounded-3 border-0 shadow-sm" type="email" placeholder="you@business.com" />
                                <small class="text-muted">Use your real business email — test addresses are not allowed.</small>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold text-dark">Phone Number</label>
                                <input asp-for="Phone" class="form-control form-control-lg rounded-3 border-0 shadow-sm" type="tel" placeholder="10-digit mobile number" />
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PinCode" class="form-label fw-semibold text-dark">Pincode</label>
                                <input asp-for="PinCode" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Area pincode" />
                                <span asp-validation-for="PinCode" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Address" class="form-label fw-semibold text-dark">Full Address</label>
                                <textarea asp-for="Address" class="form-control form-control-lg rounded-3 border-0 shadow-sm" rows="3" placeholder="Enter your full business address"></textarea>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <a asp-action="Dashboard" class="btn btn-outline-secondary btn-lg rounded-pill shadow-sm hover-scale flex-grow-1">
                                Back
                            </a>
                            <button type="submit" class="btn btn-primary-gradient btn-lg rounded-pill shadow-lg hover-scale flex-grow-1">
                                Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-gradient {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        border: none;
    }
    
    .form-control:focus {
        border-color: #a855f7;
        box-shadow: 0 0 0 0.25rem rgba(168, 85, 247, 0.25);
    }
    
    .hover-scale {
        transition: transform 0.2s;
    }
    .hover-scale:hover {
        transform: translateY(-2px);
    }
    
    .bg-primary-subtle {
        background-color: #f3e8ff !important;
    }
    
    .text-primary {
        color: #9333ea !important;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
