@model PartyClap.Models.ServiceListing

<div class="container py-4">
    <partial name="_VendorMenu" />

    <div class="card p-4 col-md-6 mx-auto">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0">Add a Service</h3>
            <a asp-action="Dashboard" asp-route-id="@Model.VendorId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
        <form asp-action="AddService" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="VendorId" />
            
            <div class="mb-3">
                <label class="form-label">Service Type</label>
                <select asp-for="ServiceType" class="form-select">
                    <option>Singer</option>
                    <option>Magician</option>
                    <option>Chef</option>
                    <option>Caterer</option>
                    <option>Decorator</option>
                    <option>Event Manager</option>
                    <option>Cleaner</option>
                    <option>Casino Games Host</option>
                </select>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            
            <!-- Main Image (Always Visible) -->
            <div class="mb-3">
                <label class="form-label">Main Service Image (Thumbnail)</label>
                <input asp-for="MediaFile" type="file" class="form-control" accept="image/*" />
                <div class="form-text">This image will be shown on the service card.</div>
            </div>

            <!-- Dynamic Fields -->
            <div id="chefFields" class="mb-3" style="display:none;">
                <label class="form-label">Cuisines (Comma separated)</label>
                <input asp-for="Attributes" class="form-control" placeholder="e.g. Italian, Mexican, Indian" />
            </div>
            
            <!-- Detailed Portfolio Uploads -->
            <div class="card bg-light p-3 mb-4">
                <h6 class="fw-bold mb-3">Portfolio Gallery (Visible to Customers)</h6>
                
                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Additional Photos <span class="text-muted small">(Multiple)</span></label>
                        <input type="file" name="PhotoFiles" class="form-control" multiple accept="image/*" />
                    </div>
                    
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Videos <span class="text-muted small">(Multiple)</span></label>
                        <input type="file" name="VideoFiles" class="form-control" multiple accept="video/*" />
                    </div>
                    
                    <div class="col-md-12 mb-3">
                        <label class="form-label">Audio Samples <span class="text-muted small">(For Singers/Musicians)</span></label>
                        <input type="file" name="AudioFiles" class="form-control" multiple accept="audio/*" />
                    </div>
                </div>
            </div>

            <script>
                document.getElementById('ServiceType').addEventListener('change', function() {
                    var type = this.value;
                    document.getElementById('chefFields').style.display = 'none';
                    
                    if (type === 'Chef' || type === 'Caterer') {
                        document.getElementById('chefFields').style.display = 'block';
                    }
                });
            </script>
            
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Weekday Cost (₹)</label>
                    <input asp-for="Cost" type="number" step="0.01" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Weekend Cost (₹)</label>
                    <input asp-for="WeekendCost" type="number" step="0.01" class="form-control" placeholder="Optional" />
                    <div class="form-text">Leave blank if same as weekday</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Per Unit</label>
                    <select asp-for="Unit" class="form-select">
                        <option>Hour</option>
                        <option>Event</option>
                        <option>Person</option>
                    </select>
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary w-100">Add Service</button>
        </form>
    </div>
</div>
