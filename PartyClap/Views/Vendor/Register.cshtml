    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Photo Upload Handler
        document.getElementById('photo-upload').addEventListener('change', function(e) {
            handleFileUpload(e.target.files, 'photo');
        });

        // Video Upload Handler
        document.getElementById('video-upload').addEventListener('change', function(e) {
            handleFileUpload(e.target.files, 'video');
        });

        // Drag and Drop for Photos
        const photoCard = document.getElementById('photo-upload-card');
        photoCard.addEventListener('dragover', (e) => {
            e.preventDefault();
            photoCard.classList.add('border-primary', 'bg-light');
        });
        photoCard.addEventListener('dragleave', () => {
            photoCard.classList.remove('border-primary', 'bg-light');
        });
        photoCard.addEventListener('drop', (e) => {
            e.preventDefault();
            photoCard.classList.remove('border-primary', 'bg-light');
            const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('image/'));
            if (files.length > 0) {
                document.getElementById('photo-upload').files = createFileList(files);
                handleFileUpload(files, 'photo');
            }
        });

        // Drag and Drop for Videos
        const videoCard = document.getElementById('video-upload-card');
        videoCard.addEventListener('dragover', (e) => {
            e.preventDefault();
            videoCard.classList.add('border-danger', 'bg-light');
        });
        videoCard.addEventListener('dragleave', () => {
            videoCard.classList.remove('border-danger', 'bg-light');
        });
        videoCard.addEventListener('drop', (e) => {
            e.preventDefault();
            videoCard.classList.remove('border-danger', 'bg-light');
            const files = Array.from(e.dataTransfer.files).filter(f => f.type.startsWith('video/'));
            if (files.length > 0) {
                document.getElementById('video-upload').files = createFileList(files);
                handleFileUpload(files, 'video');
            }
        });

        function handleFileUpload(files, type) {
            const maxFiles = 10;
            const fileArray = Array.from(files).slice(0, maxFiles);
            
            const previewContainer = document.getElementById(`${type}-preview-container`);
            const previewSection = document.getElementById(`${type}-preview`);
            const countSpan = document.getElementById(`${type}-count`);
            
            previewContainer.innerHTML = '';
            
            if (fileArray.length > 0) {
                previewSection.style.display = 'block';
                countSpan.textContent = fileArray.length;
                
                fileArray.forEach((file, index) => {
                    const fileItem = document.createElement('div');
                    fileItem.className = 'file-preview-item position-relative';
                    fileItem.style.cssText = 'width: 80px; height: 80px;';
                    
                    if (type === 'photo') {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            fileItem.innerHTML = `
                                <img src="${e.target.result}" class="w-100 h-100 object-fit-cover rounded" alt="Preview">
                                <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle" 
                                        style="width: 24px; height: 24px; padding: 0; font-size: 12px;"
                                        onclick="removeFile('photo', ${index})">×</button>
                            `;
                        };
                        reader.readAsDataURL(file);
                    } else {
                        fileItem.innerHTML = `
                            <div class="w-100 h-100 bg-light rounded d-flex flex-column align-items-center justify-content-center">
                                <i class="fas fa-video text-danger mb-1"></i>
                                <small class="text-muted" style="font-size: 10px;">${file.name.substring(0, 10)}...</small>
                            </div>
                            <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle" 
                                    style="width: 24px; height: 24px; padding: 0; font-size: 12px;"
                                    onclick="removeFile('video', ${index})">×</button>
                        `;
                    }
                    
                    previewContainer.appendChild(fileItem);
                });
            } else {
                previewSection.style.display = 'none';
            }
        }

        function removeFile(type, index) {
            const input = document.getElementById(`${type}-upload`);
            const dt = new DataTransfer();
            const files = Array.from(input.files);
            
            files.forEach((file, i) => {
                if (i !== index) dt.items.add(file);
            });
            
            input.files = dt.files;
            handleFileUpload(input.files, type);
        }

        function createFileList(files) {
            const dt = new DataTransfer();
            files.forEach(file => dt.items.add(file));
            return dt.files;
        }
    </script>
    <script>
        // Initialize basePath for vendor registration page (must be before vendor-registration.js)
        (function() {
            const basePathMeta = document.querySelector('meta[name="base-path"]');
            if (basePathMeta) {
                var basePath = basePathMeta.content;
                window.basePath = basePath.endsWith('/') ? basePath : basePath + '/';
            } else {
                // Fallback: detect from URL
                const path = window.location.pathname;
                window.basePath = path.startsWith('/PartyClap') ? '/PartyClap/' : '/';
            }
            console.log('Base path initialized to:', window.basePath);
        })();
    </script>
    <script src="~/js/vendor-registration.js"></script>
</body>
</html>
