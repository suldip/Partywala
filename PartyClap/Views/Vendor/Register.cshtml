@model PartyClap.Models.Vendor

@{
    ViewData["Title"] = "Vendor Registration";
    Layout = null; // We are defining the full layout here for the fixed header
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="base-path" content="@Url.Content("~/")" />
    <title>@PageTitles.FormatBrowserTitle("Vendor Registration")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <style>
        body.bg-light { background: linear-gradient(180deg, #FDF2F8 0%, #F8F7FF 240px, #f6f7fb 100%) !important; }

        .vendor-registration-header .logo { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
        .vendor-registration-header .logo-text {
            font-weight: 800; font-size: 1.15rem;
            background: var(--gradient);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .back-link {
            width: 38px; height: 38px; border-radius: 10px;
            display: inline-flex; align-items: center; justify-content: center;
            background: #f3f4f6; color: #374151 !important; transition: all 0.2s ease;
        }
        .back-link:hover { background: #ede9fe; color: var(--primary-color) !important; }

        /* Intro */
        .vendor-intro-badge {
            display: inline-flex; align-items: center;
            background: #fff; border: 1px solid #ecdcff; color: var(--primary-color);
            padding: 0.45rem 1.1rem; border-radius: 999px; font-weight: 600; font-size: 0.85rem;
            box-shadow: 0 4px 12px -4px rgba(139, 92, 246, 0.25);
        }
        .vendor-intro-title { font-size: 2.4rem; letter-spacing: -0.5px; }

        /* Benefit cards */
        .vendor-benefit-card {
            background: #fff; border: 1px solid #f1eaff; border-radius: 18px;
            padding: 1.75rem 1.25rem; text-align: center;
            box-shadow: 0 6px 18px -10px rgba(139, 92, 246, 0.25);
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }
        .vendor-benefit-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 32px -14px rgba(139, 92, 246, 0.4);
            border-color: #e9d5ff;
        }
        .vendor-benefit-icon {
            width: 56px; height: 56px; border-radius: 16px; margin: 0 auto 0.9rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: #fff; background: var(--gradient);
        }

        /* Wizard step icons: cleaner, larger, animated active state */
        .wizard-step-icon {
            box-shadow: 0 2px 6px rgba(0,0,0,0.06);
        }
        .wizard-step.active .wizard-step-icon {
            transform: scale(1.08);
        }

        /* Form card header accent */
        #card-title {
            position: relative; padding-left: 0.85rem;
        }
        #card-title::before {
            content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%);
            width: 5px; height: 1.4rem; border-radius: 4px; background: var(--gradient);
        }
        .card-header #card-description { padding-left: 0.85rem; }

        /* Section subheadings inside steps */
        .step-content h5.fw-bold { position: relative; }

        /* Inputs focus polish (kept compatible with existing .vendor-form-input) */
        .vendor-form-input:focus, .form-select.vendor-form-input:focus {
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.12) !important;
        }

        /* Navigation buttons */
        #btn-next, #btn-submit { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        #btn-next:hover, #btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 20px -8px rgba(0,0,0,0.25); }

        /* ---- Two-column onboarding shell ---- */
        .vendor-content-spacer { height: 84px; }
        .vendor-reg-shell { max-width: 1200px; }

        .vendor-reg-sidebar {
            background: #fff;
            border: 1px solid #f1eaff;
            border-radius: 20px;
            padding: 1.85rem 1.6rem;
            box-shadow: 0 14px 36px -18px rgba(139, 92, 246, 0.45);
        }
        @@media (min-width: 992px) {
            .vendor-reg-sidebar { position: sticky; top: 96px; }
        }
        .vendor-sidebar-title {
            font-size: 1.55rem; font-weight: 800; color: var(--dark-color);
            margin: 0.35rem 0 0.5rem; line-height: 1.25;
        }
        .vendor-sidebar-sub { color: #6b7280; font-size: 0.9rem; line-height: 1.55; margin-bottom: 1.5rem; }

        .vendor-step-rail-header {
            display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;
        }
        .vendor-step-counter {
            font-size: 0.74rem; font-weight: 700; color: var(--primary-color);
            background: #f5f3ff; padding: 0.25rem 0.65rem; border-radius: 999px;
        }

        /* Vertical step rail (overrides the horizontal premium.css defaults) */
        .vendor-step-rail { position: relative; padding: 0.25rem 0; }
        .vendor-step-rail .wizard-step {
            display: flex; flex-direction: row; align-items: center; gap: 0.85rem;
            padding: 0.5rem 0; position: relative; z-index: 1; flex: unset;
        }
        .vendor-step-rail .wizard-step-icon {
            margin: 0; width: 40px; height: 40px; font-size: 1.05rem; flex-shrink: 0;
        }
        .vendor-step-rail .wizard-step-label {
            font-size: 0.92rem; margin: 0; text-align: left; font-weight: 600;
        }
        .vendor-step-rail .wizard-step-connector {
            position: absolute; left: 19px; top: 28px; bottom: 28px;
            width: 2px; height: auto; background: #ece9f5; z-index: 0;
        }
        .vendor-step-rail .wizard-step-connector-fill { display: none; }

        /* Trust list */
        .vendor-trust { border-top: 1px solid #f1eaff; padding-top: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
        .vendor-trust-item { display: flex; gap: 0.75rem; align-items: flex-start; }
        .vendor-trust-icon {
            width: 38px; height: 38px; border-radius: 11px; flex-shrink: 0;
            background: var(--gradient); color: #fff;
            display: flex; align-items: center; justify-content: center; font-size: 0.95rem;
        }
        .vendor-trust-item strong { display: block; font-size: 0.88rem; color: var(--dark-color); }
        .vendor-trust-item span { font-size: 0.8rem; color: #6b7280; }

        @@media (max-width: 991px) {
            .vendor-reg-sidebar { margin-bottom: 1.5rem; padding: 1.25rem 1rem; }
            .vendor-sidebar-title,
            .vendor-sidebar-sub { display: none; }
            .vendor-intro-badge { margin-bottom: 0.5rem; }

            /* Horizontal stepper on tablet/mobile */
            .vendor-step-rail {
                display: flex;
                flex-direction: row;
                align-items: flex-start;
                justify-content: flex-start;
                gap: 0;
                overflow-x: auto;
                padding: 1.75rem 0.35rem 0.5rem;
                margin: 0 -0.25rem;
                scroll-snap-type: x proximity;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }
            .vendor-step-rail::-webkit-scrollbar { display: none; }

            .vendor-step-rail .wizard-step-connector {
                display: block;
                position: absolute;
                left: 1.25rem;
                right: 1.25rem;
                top: 2.1rem;
                bottom: auto;
                width: auto;
                height: 2px;
                background: #ece9f5;
            }
            .vendor-step-rail .wizard-step-connector-fill {
                display: block;
                height: 100%;
                background: linear-gradient(90deg, #10b981, #8b5cf6);
                width: 0%;
                transition: width 0.3s ease;
            }

            .vendor-step-rail .wizard-step {
                flex: 1 0 0;
                min-width: 4.5rem;
                max-width: 5.5rem;
                flex-direction: column;
                align-items: center;
                justify-content: flex-start;
                gap: 0.4rem;
                padding: 0 0.25rem;
                scroll-snap-align: center;
            }
            .vendor-step-rail .wizard-step-icon {
                width: 36px;
                height: 36px;
                font-size: 0.95rem;
                margin-bottom: 0;
            }
            .vendor-step-rail .wizard-step-label {
                font-size: 0.62rem;
                text-align: center;
                line-height: 1.2;
                max-width: 4.5rem;
            }

            .wizard-step-description {
                margin-top: 0.75rem !important;
                text-align: center;
            }
            .vendor-trust { display: none; }
        }
        @@media (max-width: 767px) {
            .vendor-sidebar-title { font-size: 1.4rem; }
            .vendor-step-rail .wizard-step { min-width: 3.75rem; }
            .vendor-step-rail .wizard-step-label { font-size: 0.58rem; }
        }

        /* Servicing locations card */
        .servicing-locations-card {
            background: #fff;
            border: 1px solid #ede9fe;
            border-radius: 18px;
            padding: 1.35rem;
            box-shadow: 0 10px 28px -16px rgba(139, 92, 246, 0.25);
        }
        .servicing-locations-header {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            margin-bottom: 1.15rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f3f4f6;
        }
        .servicing-locations-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #8b5cf6, #ec4899);
            color: #fff;
            font-size: 1rem;
            flex-shrink: 0;
        }
        .btn-add-location {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-weight: 700;
            color: #7c3aed;
            background: #f5f3ff;
            border: 1.5px dashed #c4b5fd;
            transition: all 0.2s ease;
        }
        .btn-add-location:hover {
            background: #ede9fe;
            border-color: #8b5cf6;
            color: #6d28d9;
        }
        .added-locations-panel {
            background: #faf5ff;
            border: 1px solid #e9d5ff;
            border-radius: 14px;
            padding: 1rem 1.15rem;
        }
        #locations-display .location-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: #fff;
            border: 1px solid #ddd6fe;
            color: #5b21b6;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 0.4rem 0.75rem;
            border-radius: 999px;
        }
        #locations-display .location-chip .remove-location {
            border: none;
            background: #fee2e2;
            color: #dc2626;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            font-size: 0.75rem;
            line-height: 1;
            cursor: pointer;
        }

        .service-pincode-panel {
            border: 1px solid #e9d5ff;
            border-radius: 14px;
            background: #faf5ff;
            padding: 0.85rem 1rem;
        }
        .service-pincode-search {
            border-radius: 10px !important;
            border: 1px solid #ddd6fe !important;
            font-size: 0.9rem;
        }
        .service-pincode-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 0.65rem 0 0.5rem;
            gap: 0.5rem;
        }
        .service-pincode-select-all {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.82rem;
            font-weight: 600;
            color: #5b21b6;
            margin: 0;
            cursor: pointer;
        }
        .service-pincode-list {
            max-height: 220px;
            overflow-y: auto;
            border: 1px solid #ede9fe;
            border-radius: 12px;
            background: #fff;
        }
        .service-pincode-item {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            padding: 0.55rem 0.75rem;
            border-bottom: 1px solid #f3f4f6;
            cursor: pointer;
        }
        .service-pincode-item:last-child { border-bottom: none; }
        .service-pincode-item:hover { background: #f5f3ff; }
        .service-pincode-item input { margin-top: 0.2rem; flex-shrink: 0; accent-color: #8b5cf6; }
        .service-pincode-item-label { line-height: 1.3; }
        .service-pincode-item-label strong { color: #111827; font-size: 0.88rem; }
        .service-pincode-item-label small { color: #6b7280; display: block; }
        .service-pincode-empty {
            padding: 1rem;
            text-align: center;
            color: #6b7280;
            font-size: 0.85rem;
        }

        .vendor-contact-locked {
            background-color: #f9fafb !important;
            color: #374151;
            cursor: not-allowed;
        }
        .vendor-contact-verify-banner {
            background: linear-gradient(135deg, #f5f3ff 0%, #fdf2f8 100%);
            border: 1px solid #e9d5ff;
            border-radius: 14px;
            padding: 1rem 1.15rem;
        }
        .vendor-contact-verified-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            font-size: 0.78rem;
            font-weight: 700;
            color: #059669;
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            padding: 0.3rem 0.65rem;
            border-radius: 999px;
        }
        .vendor-verify-popup .swal2-html-container { margin: 0.5rem 0 0; text-align: left; }
        .vendor-verify-popup .form-label { font-size: 0.82rem; font-weight: 600; color: #374151; margin-bottom: 0.25rem; }
        .vendor-verify-popup .form-control { border-radius: 10px; font-size: 0.92rem; }
    </style>
</head>
<body class="bg-light">

    <!-- Fixed Header -->
    <header class="vendor-registration-header">
        <div class="container">
            <div class="d-flex align-items-center gap-3">
                <a href="@Url.Action("Index", "Home")" class="text-dark text-decoration-none back-link" title="Back to home">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <partial name="_BrandLogo" view-data='new ViewDataDictionary(ViewData) { { "LogoSize", 36 }, { "LogoClass", "brand-logo" } }' />
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="d-none d-md-inline text-muted small">Already a partner?</span>
                <a href="@Url.Action("Login", "Account")" class="btn btn-sm btn-outline-dark-custom">Log In</a>
            </div>
        </div>
    </header>

    <!-- Spacer for fixed header -->
    <div class="vendor-content-spacer"></div>

    <!-- Main Content : two-column onboarding shell -->
    <div class="container vendor-reg-shell py-4">
        <div class="row g-4 g-lg-5">
            <!-- LEFT: sticky progress + benefits sidebar -->
            <aside class="col-lg-4">
                <div class="vendor-reg-sidebar">
                    <span class="vendor-intro-badge mb-3"><i class="fas fa-briefcase me-2"></i>Become a Partner</span>
                    <h1 class="vendor-sidebar-title">Start your party business</h1>
                    <p class="vendor-sidebar-sub">Free to join. Set your own prices and reach customers across 25+ cities.</p>

                    <div class="vendor-step-rail-header">
                        <span class="fw-semibold text-dark">Your progress</span>
                        <span class="vendor-step-counter">Step <span id="current-step-num">1</span> of 5</span>
                    </div>

                    <!-- Vertical step tracker (state managed by vendor-registration.js) -->
                    <div class="vendor-step-rail">
                        <div class="wizard-step-connector">
                            <div class="wizard-step-connector-fill" id="wizard-connector-fill"></div>
                        </div>
                        <div class="wizard-step active" data-step="1">
                            <div class="wizard-step-icon">👤</div>
                            <div class="wizard-step-label">Personal Info</div>
                        </div>
                        <div class="wizard-step" data-step="2">
                            <div class="wizard-step-icon">🎯</div>
                            <div class="wizard-step-label">Service Category</div>
                        </div>
                        <div class="wizard-step" data-step="3">
                            <div class="wizard-step-icon">📁</div>
                            <div class="wizard-step-label">Upload Portfolio</div>
                        </div>
                        <div class="wizard-step" data-step="4">
                            <div class="wizard-step-icon">💰</div>
                            <div class="wizard-step-label">Set Pricing</div>
                        </div>
                        <div class="wizard-step" data-step="5">
                            <div class="wizard-step-icon">✅</div>
                            <div class="wizard-step-label">Review & Submit</div>
                        </div>
                    </div>

                    <div class="wizard-step-description mt-3">
                        <p class="wizard-step-description-text mb-0" id="step-description">
                            👤 Enter your personal details and address information
                        </p>
                    </div>

                    <div class="vendor-trust mt-4">
                        <div class="vendor-trust-item"><span class="vendor-trust-icon"><i class="fas fa-indian-rupee-sign"></i></span><div><strong>Flexible pricing</strong><span>Set your own rates</span></div></div>
                        <div class="vendor-trust-item"><span class="vendor-trust-icon"><i class="fas fa-star"></i></span><div><strong>Build reputation</strong><span>Earn genuine reviews</span></div></div>
                        <div class="vendor-trust-item"><span class="vendor-trust-icon"><i class="fas fa-shield-halved"></i></span><div><strong>Verified badge</strong><span>Win customer trust</span></div></div>
                    </div>
                </div>
            </aside>

            <!-- RIGHT: form -->
            <div class="col-lg-8">
                
                <!-- Registration Form Card -->
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom p-4">
                        <h4 class="card-title fw-bold mb-1" id="card-title">Personal Information</h4>
                        <p class="card-text text-muted small mb-0" id="card-description">Provide your contact details and address information</p>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <form asp-action="Register" method="post" id="vendor-registration-form" enctype="multipart/form-data">
                            <input type="hidden" id="vendor-id" name="VendorId" value="" />
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger border-0 rounded-4" role="alert"></div>
                            }
                            
                            <!-- STEP 1: Personal Information -->
                            <div id="step-1" class="step-content active">
                                <!-- Personal Info -->
                                <div class="mb-5">
                                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                                        <h5 class="fw-bold mb-0">Personal Information</h5>
                                        <span id="contact-verified-badge" class="vendor-contact-verified-badge" style="display: none;">
                                            <i class="fas fa-check-circle"></i> Contact verified
                                        </span>
                                    </div>

                                    <div id="contact-verify-banner" class="vendor-contact-verify-banner mb-4">
                                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                                            <div>
                                                <div class="fw-semibold text-dark small">Verify your contact details first</div>
                                                <div class="text-muted small">We will send an OTP to your mobile number and save your details securely.</div>
                                            </div>
                                            <button type="button" class="btn btn-primary-gradient text-white fw-semibold px-3" id="btn-verify-contact" style="border-radius: 10px; white-space: nowrap;">
                                                <i class="fas fa-mobile-alt me-1"></i> Verify Contact
                                            </button>
                                        </div>
                                    </div>

                                    <div class="row g-3" id="vendor-contact-fields">
                                        <div class="col-md-6">
                                            <label class="vendor-form-label" for="vendor-name">First Name</label>
                                            <input asp-for="Name" id="vendor-name" class="form-control vendor-form-input" placeholder="Enter your first name"
                                                   required minlength="2" maxlength="150" pattern="[A-Za-z\s.'-]{2,150}" autocomplete="given-name">
                                            <div class="invalid-feedback">Enter a valid name (2–150 letters).</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="vendor-form-label" for="vendor-last-name">Last Name</label>
                                            <input type="text" id="vendor-last-name" name="LastName" class="form-control vendor-form-input" placeholder="Enter your last name"
                                                   required minlength="2" maxlength="150" pattern="[A-Za-z\s.'-]{2,150}" autocomplete="family-name">
                                            <div class="invalid-feedback">Enter a valid last name (2–150 letters).</div>
                                        </div>
                                        <div class="col-12">
                                            <label class="vendor-form-label" for="vendor-email">Email</label>
                                            <input asp-for="Email" id="vendor-email" type="email" class="form-control vendor-form-input" placeholder="you@example.com"
                                                   required maxlength="254" autocomplete="email">
                                            <div class="invalid-feedback">Enter a valid business email address.</div>
                                        </div>
                                        <div class="col-12">
                                            <label class="vendor-form-label" for="vendor-phone">Phone Number</label>
                                            <input asp-for="Phone" id="vendor-phone" class="form-control vendor-form-input" placeholder="9876543210"
                                                   required inputmode="tel" autocomplete="tel" maxlength="14"
                                                   pattern="^(\+91[\s-]?)?[6-9]\d{9}$" title="10-digit Indian mobile number starting with 6, 7, 8, or 9">
                                            <div class="form-text small text-muted">10-digit Indian mobile number (starts with 6–9). +91 prefix optional.</div>
                                            <div class="invalid-feedback">Enter a valid 10-digit Indian mobile number.</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Address -->
                                <div class="mb-5">
                                    <h5 class="fw-bold mb-3">Your Address</h5>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="vendor-form-label" for="vendor-address-state">State</label>
                                            <select id="vendor-address-state" class="form-select vendor-form-input" data-cascade="state" required>
                                                <option value="">Select your state</option>
                                                <option value="Maharashtra">Maharashtra</option>
                                                <option value="Delhi">Delhi</option>
                                                <option value="Karnataka">Karnataka</option>
                                                <option value="Tamil Nadu">Tamil Nadu</option>
                                                <option value="Gujarat">Gujarat</option>
                                                <option value="Rajasthan">Rajasthan</option>
                                                <option value="Uttar Pradesh">Uttar Pradesh</option>
                                                <option value="West Bengal">West Bengal</option>
                                                <option value="Telangana">Telangana</option>
                                                <option value="Andhra Pradesh">Andhra Pradesh</option>
                                                <option value="Kerala">Kerala</option>
                                                <option value="Madhya Pradesh">Madhya Pradesh</option>
                                                <option value="Punjab">Punjab</option>
                                                <option value="Haryana">Haryana</option>
                                                <option value="Bihar">Bihar</option>
                                            </select>
                                            <div class="invalid-feedback">Please select your state.</div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="vendor-form-label" for="vendor-address-city">City</label>
                                            <select id="vendor-address-city" class="form-select vendor-form-input" data-cascade="city" disabled required>
                                                <option value="">Select your city</option>
                                            </select>
                                            <div class="invalid-feedback">Please select your city.</div>
                                        </div>
                                        <div class="col-12">
                                            <label class="vendor-form-label" for="main-pincode-input">Pin Code</label>
                                            <div class="position-relative">
                                                <input asp-for="PinCode" id="main-pincode-input" class="form-control vendor-form-input" placeholder="Search pin code or area (e.g., 110001)"
                                                       autocomplete="postal-code" inputmode="numeric" required maxlength="6"
                                                       pattern="[1-9][0-9]{5}" title="6-digit Indian pin code">
                                                <div id="pincode-autocomplete" class="pincode-autocomplete-dropdown" style="display: none;"></div>
                                                <small class="text-muted mt-1 d-block">Enter a valid 6-digit Indian pin code.</small>
                                                <div class="invalid-feedback">Pin code must be exactly 6 digits and cannot start with 0.</div>
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <label class="vendor-form-label" for="vendor-address">Street Address</label>
