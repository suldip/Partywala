@section Styles {
<style>
/* ===== Home page polish (attractive + user-friendly) ===== */
.hero-section { position: relative; overflow: hidden; }
.hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: .5;
    pointer-events: none;
    z-index: 0;
}
.hero-blob-1 { width: 360px; height: 360px; top: -120px; left: -90px; background: radial-gradient(circle, #ddd6fe, transparent 70%); }
.hero-blob-2 { width: 380px; height: 380px; top: -100px; right: -120px; background: radial-gradient(circle, #fbcfe8, transparent 70%); }

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    background: rgba(139, 92, 246, .12);
    color: #7c3aed;
    font-weight: 600;
    font-size: .85rem;
    padding: .4rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
}

.hero-chips {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: .5rem;
}
.hero-chips-label { color: #6b7280; font-size: .85rem; font-weight: 600; margin-right: .25rem; }
.hero-chip {
    background: #fff;
    border: 1px solid #ececf3;
    border-radius: 999px;
    padding: .4rem .9rem;
    font-size: .85rem;
    font-weight: 600;
    color: #4b5563;
    text-decoration: none;
    box-shadow: 0 2px 8px -4px rgba(0,0,0,.15);
    transition: all .2s ease;
}
.hero-chip:hover {
    color: #7c3aed;
    border-color: #c4b5fd;
    transform: translateY(-2px);
}

.hero-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: .75rem;
    margin-top: 1.75rem;
}
.hero-trust-avatars { display: flex; }
.hero-trust-avatars img {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid #fff;
    margin-left: -10px;
    box-shadow: 0 2px 6px rgba(0,0,0,.12);
}
.hero-trust-avatars img:first-child { margin-left: 0; }
.hero-trust-text { color: #4b5563; font-size: .9rem; }
.hero-trust-stars { color: #f59e0b; letter-spacing: 1px; margin-right: .35rem; }

/* Section eyebrow label */
.section-eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .75rem;
    font-weight: 700;
    color: #ec4899;
    background: #fdf2f8;
    padding: .3rem .8rem;
    border-radius: 999px;
    margin-bottom: .85rem;
}

/* Service emoji badge */
.service-emoji {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    background: linear-gradient(135deg, #f5f3ff, #fdf2f8);
    flex-shrink: 0;
}

/* How it works */
.how-step {
    background: #fff;
    border: 1px solid #f1f0f7;
    border-radius: 18px;
    padding: 2rem 1.25rem 1.5rem;
    text-align: center;
    height: 100%;
    position: relative;
    transition: all .3s ease;
}
.how-step:hover { transform: translateY(-5px); box-shadow: 0 16px 30px -18px rgba(124,58,237,.4); border-color: #e9d5ff; }
.how-step-num {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8b5cf6, #ec4899);
    color: #fff;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 14px -6px rgba(236,72,153,.7);
}
.how-step-icon { font-size: 2rem; margin: .5rem 0 .75rem; }

/* Stats band */
.stats-band {
    background: linear-gradient(135deg, #faf5ff 0%, #fdf2f8 100%);
    border: 1px solid #f3e8ff;
    border-radius: 24px;
    padding: 2.5rem 1.5rem;
}
.stats-band .stat-cell { position: relative; }
@@media (min-width: 768px) {
    .stats-band .stat-cell:not(:last-child)::after {
        content: "";
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%);
        height: 48px;
        width: 1px;
        background: #eaddff;
    }
}
</style>
}
