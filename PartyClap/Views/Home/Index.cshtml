@{
    ViewData["Title"] = "Book Party Vendors & Event Services";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
    <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
    <div class="container position-relative">
        <span class="hero-badge animate__animated animate__fadeInDown">
            <i class="bi bi-stars"></i> India's most-loved party booking platform
        </span>
        <h1 class="hero-title">
            <span class="text-gradient">Make Your Party</span><br>
            <span class="text-gradient">Unforgettable!</span>
        </h1>
        <p class="hero-subtitle mb-4">
            Book skilled vendors for singers, chefs, magicians, event managers, and more. Create magical moments with India's best party professionals.
        </p>

        <!-- Smart Search Bar -->
        <div class="search-container mx-auto mb-3 animate__animated animate__fadeInUp animate__delay-1s">
            <form asp-controller="Customer" asp-action="Explore" method="get" class="search-glass d-flex align-items-center flex-wrap p-2 rounded-pill shadow-lg bg-white bg-opacity-75 blur-md">
                <div class="flex-grow-1 px-3 d-flex align-items-center border-end search-input-group">
                    <i class="bi bi-search text-muted me-2"></i>
                    <input type="text" name="search" class="form-control border-0 bg-transparent shadow-none" placeholder="Search for singers, magicians, chefs...">
                </div>
               @*  <div class="px-3 d-none d-md-flex align-items-center location-input-group border-end">
                    <i class="bi bi-geo-alt text-muted me-2"></i>
                    <input type="text" name="pinCode" class="form-control border-0 bg-transparent shadow-none" placeholder="PIN code" style="max-width: 120px;" pattern="[0-9]{6}" title="Enter a 6-digit PIN code" inputmode="numeric" maxlength="6">
                </div> *@
                <button type="submit" class="btn btn-primary-gradient rounded-pill px-4 ms-2 py-2">
                    <span class="d-none d-sm-inline">Find Vendors</span>
                    <i class="bi bi-arrow-right d-sm-none"></i>
                </button>
            </form>
        </div>

        <!-- Popular search chips -->
        <div class="hero-chips mb-4">
            <span class="hero-chips-label">Popular:</span>
            <a asp-controller="Customer" asp-action="Explore" asp-route-category="Music" class="hero-chip">🎤 Singers</a>
            <a asp-controller="Customer" asp-action="Explore" asp-route-category="Catering" class="hero-chip">👨‍🍳 Caterers</a>
            <a asp-controller="Customer" asp-action="Explore" asp-route-category="Decoration" class="hero-chip">🎈 Decorators</a>
            <a asp-controller="Customer" asp-action="Explore" asp-route-category="Photography" class="hero-chip">📸 Photographers</a>
        </div>

        <div class="d-flex justify-content-center gap-3 hero-btns">
            <a asp-controller="Customer" asp-action="Explore" class="btn btn-primary-gradient btn-lg px-5">Book Now</a>
            <a asp-controller="Vendor" asp-action="Register" class="btn btn-outline-dark-custom btn-lg px-5">Join as Vendor</a>
        </div>

        <!-- Social proof -->
        <div class="hero-trust">
            <div class="hero-trust-avatars">
                <img src="https://ui-avatars.com/api/?name=P+S&background=8B5CF6&color=fff&bold=true" alt="">
                <img src="https://ui-avatars.com/api/?name=R+K&background=EC4899&color=fff&bold=true" alt="">
                <img src="https://ui-avatars.com/api/?name=A+P&background=2563EB&color=fff&bold=true" alt="">
                <img src="https://ui-avatars.com/api/?name=S+M&background=16A34A&color=fff&bold=true" alt="">
            </div>
            <div class="hero-trust-text">
                <span class="hero-trust-stars">★★★★★</span>
                <span><strong>4.8/5</strong> from 10,000+ happy customers</span>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
