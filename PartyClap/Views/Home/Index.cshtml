                    <h5 class="fw-bold mb-2">Easy Booking</h5>
                    <p class="text-muted small mb-0">Simple booking process with instant confirmation.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="section-eyebrow">Simple &amp; quick</span>
            <h2 class="fw-bold mb-2">How It Works</h2>
            <p class="text-muted mx-auto" style="max-width: 560px;">From search to celebration in four easy steps.</p>
        </div>
        <div class="row g-4 how-steps">
            <div class="col-md-3 col-sm-6">
                <div class="how-step">
                    <div class="how-step-num">1</div>
                    <div class="how-step-icon">🔍</div>
                    <h6 class="fw-bold mb-1">Search</h6>
                    <p class="text-muted small mb-0">Find vendors by service, city, or PIN code.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="how-step">
                    <div class="how-step-num">2</div>
                    <div class="how-step-icon">⚖️</div>
                    <h6 class="fw-bold mb-1">Compare</h6>
                    <p class="text-muted small mb-0">Check ratings, portfolios, and transparent pricing.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="how-step">
                    <div class="how-step-num">3</div>
                    <div class="how-step-icon">💳</div>
                    <h6 class="fw-bold mb-1">Book</h6>
                    <p class="text-muted small mb-0">Pay just 20% advance to unlock contact details.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="how-step">
                    <div class="how-step-num">4</div>
                    <div class="how-step-icon">🎉</div>
                    <h6 class="fw-bold mb-1">Celebrate</h6>
                    <p class="text-muted small mb-0">Enjoy a worry-free, unforgettable event.</p>
                </div>
            </div>
        </div>
    </div>
</section>

