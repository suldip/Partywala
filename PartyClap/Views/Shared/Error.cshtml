@{
    ViewData["Title"] = "Something Went Wrong";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 text-center">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <div class="text-danger mb-3">
                    <i class="bi bi-exclamation-triangle display-1"></i>
                </div>
                <h1 class="fw-bold mb-3">@ViewData["Title"]</h1>
                <p class="text-muted mb-4">
                    We ran into an unexpected problem while processing your request.
                    Please try again in a moment, or return to the homepage.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4">
                        <i class="bi bi-house me-2"></i>Go Home
                    </a>
                    <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-envelope me-2"></i>Contact Support
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
