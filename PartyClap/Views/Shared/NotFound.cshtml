@{
    ViewData["Title"] = "Page Not Found";
    var message = ViewData["Message"] as string ?? "The page you're looking for doesn't exist or may have been removed.";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 text-center">
            <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                <div class="display-1 fw-bold text-primary mb-2" style="line-height: 1;">404</div>
                <h1 class="fw-bold mb-3">@ViewData["Title"]</h1>
                <p class="text-muted mb-4">@message</p>
                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-center">
                    <a href="@Url.Action("Explore", "Customer")" class="btn btn-primary px-4">
                        <i class="bi bi-search me-2"></i>Browse Services
                    </a>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-house me-2"></i>Go Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
