@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@inject IWebHostEnvironment HostEnvironment

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        var routeController = ViewContext.RouteData.Values["controller"]?.ToString();
        var routeAction = ViewContext.RouteData.Values["action"]?.ToString();
        var pageTitle = PageTitles.Resolve(ViewData["Title"] as string, routeController, routeAction);
    }
    <title>@PageTitles.FormatBrowserTitle(pageTitle)</title>
    
    <!-- PWA Support -->
    <link rel="manifest" href="~/manifest.json">
    <meta name="theme-color" content="#8B5CF6">
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="~/images/icon-192.png">
    <link rel="apple-touch-icon" href="~/images/apple-touch-icon.png">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="PartyClap">
    <meta name="base-path" content="@Url.Content("~/")">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PartyClap.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    <!-- External Libraries -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(((ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" || ViewContext.RouteData.Values["controller"]?.ToString() == "Vendor") && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard") ? "page-dashboard" : "")">
    <script>
        // Global handler for server-side messages
        document.addEventListener('DOMContentLoaded', function() {
            @if (TempData["SuccessMessage"] != null) {
                <text>window.SmartPop.toast('@TempData["SuccessMessage"]', 'success');</text>
            }
            @if (TempData["ErrorMessage"] != null) {
                <text>window.SmartPop.error('Oops!', '@TempData["ErrorMessage"]');</text>
            }
            @if (TempData["InfoMessage"] != null) {
                <text>window.SmartPop.toast('@TempData["InfoMessage"]', 'info');</text>
            }
        });

        window.isUserLoggedIn = @((HttpContextAccessor.HttpContext?.User?.Identity?.IsAuthenticated ?? false).ToString().ToLower());
        // Base path for API calls and navigation - ensure trailing slash
        var basePath = '@Url.Content("~/")';
        if (!basePath || basePath === '/') {
            var pathMatch = window.location.pathname || '';
            if (pathMatch.indexOf('/PartyClap/') === 0 || pathMatch === '/PartyClap') {
                basePath = '/PartyClap/';
            }
        }
        window.basePath = basePath.endsWith('/') ? basePath : basePath + '/';
    </script>
    @{
        var httpCtx = HttpContextAccessor.HttpContext;
        var role = httpCtx?.User?.Identity?.IsAuthenticated == true ? httpCtx.GetUserRole() : null;
        var userName = httpCtx?.User?.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
            ?? httpCtx?.Session.GetString("UserName");
    }
    <nav class="navbar navbar-expand-lg sticky-top py-2 shadow-sm">
        <div class="container d-flex justify-content-between align-items-center">
            <!-- Brand -->
            <partial name="_BrandLogo" view-data='new ViewDataDictionary(ViewData) { { "LogoSize", 40 }, { "LogoClass", "brand-logo me-2 flex-shrink-0" } }' />

            <!-- Mobile: Quick Actions & Toggler -->
            <div class="d-flex align-items-center gap-2 d-lg-none mobile-header-actions">
                <!-- Legal Support Always Visible on Mobile -->
                <a class="nav-link p-1 text-primary border-0" asp-controller="Home" asp-action="TrustCenter" title="Legal Support">
                    <i class="bi bi-shield-lock fs-5"></i>
                </a>

                @if (role == "Customer" || role == "Vendor" || string.IsNullOrEmpty(role))
                {
                    <div class="dropdown">
                        <button class="mobile-notif-bell" type="button" id="mobileNotificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                            </svg>
                            <span class="badge bg-danger position-absolute" id="mobile-notification-badge" style="display: none;">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="mobileNotificationDropdown">
                            <div class="dropdown-header d-flex justify-content-between align-items-center">
                                <span class="fw-bold">Notifications</span>
                                <a href="#" class="small text-white" onclick="return markAllAsRead()">Mark all read</a>
                            </div>
                            <div class="dropdown-divider m-0"></div>
                            <div id="mobile-notification-list">
                                <div class="dropdown-item text-center text-muted">Loading...</div>
                            </div>
                        </div>
                    </div>
                }

                @if (string.IsNullOrEmpty(role))
                {
                    <a class="btn btn-sm btn-outline-primary border-0 px-2 py-1 fw-bold" asp-controller="Account" asp-action="Login">Login</a>
                }
                else
                {
                    <a class="nav-link p-1 text-danger" asp-controller="Account" asp-action="Logout" title="Logout">
                        <i class="bi bi-box-arrow-right fs-5"></i>
                    </a>
                }

                <button class="navbar-toggler border-0 shadow-none p-1 ms-1" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <i class="bi bi-list fs-3 text-dark"></i>
                </button>
            </div>

            <!-- desktop/Collapse Menu -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-3">
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="TrustCenter">
                            <i class="bi bi-shield-lock me-1"></i> Legal Support
                        </a>
                    </li>
                    @if (role == "Customer" || role == "Vendor" || string.IsNullOrEmpty(role))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link notification-bell position-relative" href="#" id="notificationDropdown" 
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                                </svg>
                                <span class="badge bg-danger" id="notification-badge" style="display: none;">0</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end notification-dropdown" 
                                 aria-labelledby="notificationDropdown">
                                <div class="dropdown-header d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">Notifications</span>
                                    <a href="#" class="small text-white" onclick="return markAllAsRead()">Mark all read</a>
                                </div>
                                <div class="dropdown-divider m-0"></div>
                                <div id="notification-list">
                                    <div class="dropdown-item text-center text-muted">Loading...</div>
                                </div>
                            </div>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Customer" asp-action="ViewCart">
                                <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                </svg>
                                <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none; font-size: 0.6rem;">0</span>
                            </a>
                        </li>
                    }

                    @if (!string.IsNullOrEmpty(role))
                    {
                        <li class="nav-item d-none d-lg-block">
                            <span class="nav-link text-dark fw-bold">
                                <i class="bi bi-person-circle me-1"></i> Hello, @userName
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold text-danger" asp-controller="Account" asp-action="Logout">Logout</a>
                        </li>
                        <li class="nav-item">
                            @if (role == "Admin") { <a class="btn btn-primary-gradient" asp-controller="Admin" asp-action="Dashboard">Dashboard</a> }
                            else if (role == "Vendor") { <a class="btn btn-primary-gradient" asp-controller="Vendor" asp-action="Dashboard">Dashboard</a> }
                            else { <a class="btn btn-primary-gradient" asp-controller="Customer" asp-action="Dashboard">Dashboard</a> }
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-controller="Account" asp-action="Login">Log In</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary-gradient" asp-controller="Vendor" asp-action="Register">Get Started</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Mobile Bottom Navigation (Visible only on mobile) -->
    <div class="mobile-bottom-nav d-lg-none d-flex justify-content-around py-2 border-top bg-white fixed-bottom shadow-lg z-3">
        <a asp-controller="Home" asp-action="Index" class="nav-item text-center text-decoration-none @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "text-muted")">
            <i class="bi bi-house-door fs-4 d-block"></i>
            <span class="small">Home</span>
        </a>
        <a asp-controller="Customer" asp-action="Explore" class="nav-item text-center text-decoration-none @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" && ViewContext.RouteData.Values["action"]?.ToString() == "Explore" ? "active" : "text-muted")">
            <i class="bi bi-search fs-4 d-block"></i>
            <span class="small">Explore</span>
        </a>
        <a asp-controller="Customer" asp-action="ViewCart" class="nav-item text-center text-decoration-none position-relative @(ViewContext.RouteData.Values["action"]?.ToString() == "ViewCart" ? "active" : "text-muted")">
            <i class="bi bi-bag fs-4 d-block"></i>
            <span class="small">Cart</span>
            <span id="mobile-cart-badge" class="position-absolute top-0 start-50 translate-middle-y badge rounded-pill bg-danger" style="display: none; font-size: 0.6rem; transform: translateX(5px);">0</span>
        </a>
        @if (!string.IsNullOrEmpty(role))
        {
            <a asp-controller="Account" asp-action="Logout" class="nav-item text-center text-decoration-none text-muted">
                <i class="bi bi-box-arrow-right fs-4 d-block text-danger"></i>
                <span class="small">Logout</span>
            </a>
            <a asp-controller="@role" asp-action="Dashboard" class="nav-item text-center text-decoration-none @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "text-muted")">
                <i class="bi bi-person fs-4 d-block"></i>
                <span class="small">Account</span>
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="nav-item text-center text-decoration-none @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "text-muted")">
                <i class="bi bi-person fs-4 d-block"></i>
                <span class="small">Login</span>
            </a>
        }
    </div>

    <style>
        /* Aggressive Horizontal Scroll Fix */
        html, body {
            overflow-x: hidden !important;
            width: 100% !important;
            max-width: 100% !important;
            position: relative;
            margin: 0;
            padding: 0;
        }
        
        /* Mobile Bottom Nav Fix */
        .mobile-bottom-nav {
            position: fixed !important;
            bottom: 0 !important;
            left: 0 !important;
            right: 0 !important;
            width: 100% !important;
            height: 70px !important;
            background: #ffffff !important;
            box-shadow: 0 -4px 15px rgba(0,0,0,0.08) !important;
            z-index: 9999 !important; /* Extremely high z-index */
            border-top: 1px solid #f1f5f9 !important;
            padding-bottom: env(safe-area-inset-bottom, 0);
            display: flex !important;
            justify-content: space-around !important;
            align-items: center !important;
        }

        .mobile-bottom-nav .nav-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            position: relative;
            color: #64748b !important;
            text-decoration: none !important;
        }
        
        .mobile-bottom-nav .nav-item i {
            font-size: 1.4rem;
            margin-bottom: 2px;
            transition: transform 0.3s ease;
        }
        
        .mobile-bottom-nav .nav-item span {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.2px;
        }
        
        .mobile-bottom-nav .nav-item.active {
            color: #8B5CF6 !important; /* Specific primary color */
        }
        
        .mobile-bottom-nav .nav-item.active i {
            transform: translateY(-4px);
        }

        /* Ensure content doesn't get hidden behind bottom nav */
        @@media (max-width: 991px) {
            body {
                padding-bottom: 85px !important;
            }
            .mobile-bottom-nav {
                display: flex !important;
            }
        }
        
        @@media (min-width: 992px) {
            .mobile-bottom-nav {
                display: none !important;
            }
        }
    </style>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Admin & Vendor Access (hidden for customers/admins — not relevant on their dashboards) -->
    @if (role != "Customer" && role != "Admin")
    {
    <section class="admin-access-section">
        <div class="container">
            <div class="row g-4 justify-content-center">
                <div class="col-12 text-center mb-4">
                    <h2 class="text-white fw-bold mb-2">Admin & Vendor Access</h2>
                    <p class="text-muted">Quick access to management dashboards</p>
                </div>
                
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="admin-card">
                        <div class="admin-icon mb-3">
                            <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <h6 class="text-white fw-bold mb-2">Vendor Account</h6>
                        <p class="text-muted small mb-3">Manage your services and profile</p>
                        <a asp-controller="Vendor" asp-action="Register" class="btn btn-primary-gradient btn-sm w-100">
                            Access Portal
                        </a>
                    </div>
                </div>
                
                <div class="col-lg-3 col-md-4 col-sm-6">
                    @if (role == "Vendor")
                    {
                        <div class="admin-card">
                            <div class="admin-icon mb-3">
                                <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                                </svg>
                            </div>
                            <h6 class="text-white fw-bold mb-2">Vendor Dashboard</h6>
                            <p class="text-muted small mb-3">Track bookings and earnings</p>
                            <a asp-controller="Vendor" asp-action="Dashboard" class="btn btn-primary-gradient btn-sm w-100">
                                Open Dashboard
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="admin-card">
                            <div class="admin-icon mb-3">
                                <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                            <h6 class="text-white fw-bold mb-2">Vendor Login</h6>
                            <p class="text-muted small mb-3">Sign in with your vendor account</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary-gradient btn-sm w-100">
                                Vendor Sign In
                            </a>
                        </div>
                    }
                </div>
                

            </div>
        </div>
    </section>
    }

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row g-4 pb-4">
                <!-- Brand Column -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <partial name="_BrandLogo" view-data='new ViewDataDictionary(ViewData) { { "LogoSize", 36 }, { "LogoClass", "brand-logo flex-shrink-0" }, { "LogoLight", true } }' />
                    <p class="footer-text">Making every celebration special with India's best party professionals.</p>
                </div>

                <!-- Quick Links Column -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h6 class="footer-title">Quick Links</h6>
                    <a asp-controller="Home" asp-action="Index" class="footer-link">Home</a>
                    <a asp-controller="Customer" asp-action="Explore" class="footer-link">Explore Vendors</a>
                    <a asp-controller="Vendor" asp-action="Register" class="footer-link">Become a Vendor</a>
                    <a asp-controller="Home" asp-action="Contact" class="footer-link">Contact Us</a>
                </div>

                <!-- Support Column -->
                <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                    <h6 class="footer-title">Support</h6>
                    <a asp-controller="Home" asp-action="Contact" class="footer-link">Help Center</a>
                    <a asp-controller="Home" asp-action="TrustCenter" class="footer-link">Terms &amp; Conditions</a>
                    <a asp-controller="Home" asp-action="Privacy" class="footer-link">Privacy Policy</a>
                    <a asp-controller="Home" asp-action="TrustCenter" class="footer-link">
                        <i class="bi bi-shield-lock me-1"></i> Legal Support
                    </a>
                </div>

                <!-- Services Column -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-title">Our Services</h6>
                    <a asp-controller="Customer" asp-action="Explore" class="footer-link">Singers</a>
                    <a asp-controller="Customer" asp-action="Explore" class="footer-link">Chefs</a>
                    <a asp-controller="Customer" asp-action="Explore" class="footer-link">Event Managers</a>
                    <a asp-controller="Customer" asp-action="Explore" class="footer-link">Photographers</a>
                </div>
            </div>

            <!-- Copyright -->
            <div class="border-top border-secondary pt-4 mt-2 text-center">
                <p class="footer-text mb-0">&copy; 2025 PartyClap. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- PWA Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                @if (HostEnvironment.IsDevelopment())
                {
                    <text>
                navigator.serviceWorker.getRegistrations().then(function (registrations) {
                    registrations.forEach(function (registration) { registration.unregister(); });
                });
                    </text>
                }
                else
                {
                    <text>
                navigator.serviceWorker.register('/PartyClap/sw.js')
                    .then(function () { console.log('Service Worker: Registered'); })
                    .catch(function (err) { console.log('Service Worker: Error:', err); });
                    </text>
                }
            });
        }
    </script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script src="~/js/cart-manager.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
