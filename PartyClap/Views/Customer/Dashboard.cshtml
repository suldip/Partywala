@model List<PartyClap.Models.Booking>

@{
    ViewData["Title"] = "Customer Dashboard";
    var customer = ViewBag.Customer as PartyClap.Models.Customer;
    var walletTransactions = ViewBag.WalletTransactions as List<PartyClap.Models.WalletTransaction>;
    var serviceRequestsList = ViewBag.ServiceRequests as List<Dictionary<string, object>>;
    var addresses = ViewBag.Addresses as List<PartyClap.Models.Address>;
    var activeSection = ViewBag.Section as string ?? "Overview";
    var reviewedBookingIds = ViewBag.ReviewedBookingIds as HashSet<string> ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
}

<style>
    :root {
        --sidebar-width: 280px;
        --sidebar-collapsed-width: 85px;
        --sidebar-bg: #ffffff;
        --primary-gradient: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
        --primary-color: #8b5cf6;
        --content-bg: #f8f7fc;
        --card-shadow: 0 12px 32px rgba(124, 58, 237, 0.07);
    }

    .dashboard-wrapper {
        display: flex;
        min-height: calc(100vh - 70px);
        background-color: var(--content-bg);
        position: relative;
    }

    /* Sidebar Styles */
    .dashboard-sidebar {
        width: var(--sidebar-width);
        background: var(--sidebar-bg);
        border-right: 1px solid #eee;
        padding: 1.5rem 0;
        display: flex;
        flex-direction: column;
        position: sticky;
        top: 70px;
        height: calc(100vh - 70px);
        z-index: 1000;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow-y: auto;
        overflow-x: hidden;
    }

    .dashboard-sidebar.collapsed {
        width: var(--sidebar-collapsed-width);
    }

    .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 1rem 1rem;
    }

    #sidebarToggle {
        background: #f8f9fa;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        color: #6c757d;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

    #sidebarToggle:hover {
        background: #f5f3ff;
        color: var(--primary-color);
    }

    .sidebar-user {
        padding: 0 1.5rem 2rem;
        text-align: center;
        border-bottom: 1px solid #f0f0f0;
        margin-bottom: 1rem;
        transition: opacity 0.3s;
    }

    .dashboard-sidebar.collapsed .sidebar-user {
        opacity: 0;
        height: 0;
        padding: 0;
        margin: 0;
        overflow: hidden;
    }

    .user-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        margin: 0 auto 10px;
        background: var(--primary-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(139, 92, 246, 0.35);
        overflow: hidden;
    }

    .user-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
        flex-grow: 1;
    }

    .menu-item {
        margin: 5px 15px;
    }

    .menu-link {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        color: #6c757d;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .menu-link i {
        font-size: 1.25rem;
        margin-right: 15px;
        transition: all 0.3s ease;
    }

    .menu-link span {
        transition: opacity 0.3s, transform 0.3s;
        white-space: nowrap;
    }

    .dashboard-sidebar.collapsed .menu-link span {
        opacity: 0;
        transform: translateX(-10px);
        pointer-events: none;
        width: 0;
    }

    .dashboard-sidebar.collapsed .menu-link {
        justify-content: center;
        padding: 12px;
    }

    .dashboard-sidebar.collapsed .menu-link i {
        margin-right: 0;
        font-size: 1.5rem;
    }

    .menu-link:hover {
        background: #f5f3ff;
        color: var(--primary-color);
    }

    .menu-link.active {
        background: var(--primary-gradient);
        color: white;
        box-shadow: 0 6px 18px rgba(139, 92, 246, 0.35);
    }

    .menu-link.active i {
        color: white;
    }

    /* Main Content Styles */
    .dashboard-content {
        flex-grow: 1;
        padding: 2rem;
        overflow-x: hidden;
    }

    .section-header {
        margin-bottom: 2rem;
    }

    /* Card Styles */
    .glass-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #f1eefb;
        box-shadow: var(--card-shadow);
        padding: 1.5rem;
        margin-bottom: 2rem;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .glass-card.text-center:hover,
    .glass-card.h-100:hover {
        transform: translateY(-4px);
        border-color: #e9d5ff;
        box-shadow: 0 18px 36px -18px rgba(124, 58, 237, 0.35);
    }

    /* Wallet specific */
    .wallet-card-new {
        background: var(--primary-gradient);
        border-radius: 20px;
        padding: 30px;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .wallet-card-new::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        animation: pulse 15s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    /* Responsive */
    @@media (max-width: 991px) {
        .dashboard-sidebar {
            width: var(--sidebar-collapsed-width);
        }
        .sidebar-user, .sidebar-header {
            display: none;
        }
        .menu-link i {
            margin-right: 0.35rem;
            font-size: 1.15rem;
        }
        .menu-item {
            margin: 5px 10px;
        }
    }

    @@media (max-width: 768px) {
        .dashboard-wrapper {
            flex-direction: column;
        }
        .dashboard-sidebar {
            width: 100%;
            height: auto;
            position: relative;
            top: 0;
            padding: 1rem 0;
            border-right: none;
            border-bottom: 1px solid #eee;
        }
        .sidebar-menu {
            display: flex;
            overflow-x: auto;
            padding: 0 10px;
        }
        .menu-item {
            margin: 0 5px;
            flex-shrink: 0;
        }
    }
</style>

<div class="dashboard-wrapper page-dashboard">
    <!-- Sidebar -->
    <aside class="dashboard-sidebar" id="mainSidebar">
        <div class="sidebar-header">
            <button id="sidebarToggle" title="Toggle Sidebar">
                <i class="bi bi-layout-sidebar-inset"></i>
            </button>
        </div>
        <div class="sidebar-user">
            <div class="user-avatar">
                @if (!string.IsNullOrEmpty(customer?.ProfilePicture))
                {
                    <img src="@customer.ProfilePicture" alt="@customer.Name" />
                }
                else
                {
                    @customer?.Name?.Substring(0, 1).ToUpper()
                }
            </div>
            <h6 class="mb-0 fw-bold">@customer?.Name</h6>
            <small class="text-muted">@customer?.Email</small>
        </div>

        <ul class="sidebar-menu">
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Overview" })" class="menu-link @(activeSection == "Overview" ? "active" : "")">
                    <i class="bi bi-grid-fill"></i>
                    <span>Overview</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Bookings" })" class="menu-link @(activeSection == "Bookings" ? "active" : "")">
                    <i class="bi bi-calendar-check-fill"></i>
                    <span>My Bookings</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "ServiceRequests" })" class="menu-link @(activeSection == "ServiceRequests" ? "active" : "")">
                    <i class="bi bi-chat-left-dots-fill"></i>
                    <span>Service Requests</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Messages" })" class="menu-link @(activeSection == "Messages" ? "active" : "")">
                    <i class="bi bi-envelope-fill"></i>
                    <span>Messages</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Wallet" })" class="menu-link @(activeSection == "Wallet" ? "active" : "")">
                    <i class="bi bi-wallet2"></i>
                    <span>Wallet & Payments</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Profile" })" class="menu-link @(activeSection == "Profile" ? "active" : "")">
                    <i class="bi bi-person-fill"></i>
                    <span>My Profile</span>
                </a>
            </li>
            <li class="menu-item">
                <a href="@Url.Action("Dashboard", new { section = "Addresses" })" class="menu-link @(activeSection == "Addresses" ? "active" : "")">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span>Saved Addresses</span>
                </a>
            </li>
            <li class="menu-item mt-auto">
                <a href="@Url.Action("Logout", "Account")" class="menu-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Logout</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="dashboard-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @switch (activeSection)
        {
            case "Overview":
                <div class="section-header">
                    <h2 class="fw-bold">Welcome back, @customer?.Name! 👋</h2>
                    <p class="text-muted">Here's what's happening with your events.</p>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="glass-card shadow-sm h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="p-3 rounded-4 bg-primary bg-opacity-10 text-primary me-3">
                                    <i class="bi bi-calendar-event fs-3"></i>
                                </div>
                                <div>
                                    <h3 class="mb-0 fw-bold">@Model?.Count</h3>
                                    <p class="text-muted small mb-0">Total Bookings</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-card shadow-sm h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="p-3 rounded-4 bg-success bg-opacity-10 text-success me-3">
                                    <i class="bi bi-wallet fs-3"></i>
                                </div>
                                <div>
                                    <h3 class="mb-0 fw-bold">₹@customer?.WalletBalance.ToString("N0")</h3>
                                    <p class="text-muted small mb-0">Wallet Balance</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        @{
                            string tier = ViewBag.LoyaltyTier as string ?? "Bronze";
                            string tierIcon = "🥉";
                            if (tier == "Silver") tierIcon = "🥈";
                            else if (tier == "Gold") tierIcon = "🥇";
                        }
                        <div class="glass-card shadow-sm h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="p-3 rounded-4 bg-warning bg-opacity-10 text-warning me-3">
                                    <span class="fs-3">@tierIcon</span>
                                </div>
                                <div>
                                    <h3 class="mb-0 fw-bold">@tier</h3>
                                    <p class="text-muted small mb-0">Member Tier</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="glass-card">
                            <h5 class="fw-bold mb-4">Recent Bookings</h5>
                            @if (Model != null && Model.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead>
                                            <tr class="text-muted small">
                                                <th>EVENT</th>
                                                <th>DATE</th>
                                                <th>STATUS</th>
                                                <th>ACTION</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var booking in Model.Take(5))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold">@booking.Id.Substring(0, 8)</div>
                                                        <div class="small text-muted">₹@booking.CustomerTotalCost</div>
                                                    </td>
                                                    <td>@booking.EventDate.ToString("MMM dd, yyyy")</td>
                                                    <td>
                                                        @if (booking.Status == "Confirmed")
                                                        {
                                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Confirmed</span>
                                                        }
                                                        else if (booking.Status == "Pending" || booking.Status == "Requested")
                                                        {
                                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">Pending</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">@booking.Status</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        <a href="@Url.Action("Dashboard", new { section = "Bookings" })" class="btn btn-sm btn-light rounded-pill">View</a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <p class="text-muted">No bookings yet.</p>
                                    <a href="@Url.Action("Explore")" class="btn btn-primary rounded-pill px-4">Find Services</a>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="glass-card">
                            <h5 class="fw-bold mb-4">Recent Wallet Activity</h5>
                            @if (walletTransactions != null && walletTransactions.Any())
                            {
                                @foreach (var txn in walletTransactions.Take(3))
                                {
                                    <div class="d-flex align-items-center mb-3 pb-3 border-bottom border-light">
                                        <div class="p-2 rounded-3 @(txn.TransactionType == "Credit" ? "bg-success" : "bg-danger") bg-opacity-10 @(txn.TransactionType == "Credit" ? "text-success" : "text-danger") me-3">
                                            <i class="bi bi-arrow-@(txn.TransactionType == "Credit" ? "up-left" : "down-right")"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 small fw-bold">@txn.Description</h6>
                                            <small class="text-muted">@txn.TransactionDate.ToString("MMM dd, HH:mm")</small>
                                        </div>
                                        <div class="fw-bold @(txn.TransactionType == "Credit" ? "text-success" : "text-danger")">
                                            @(txn.TransactionType == "Credit" ? "+" : "-")₹@txn.Amount.ToString("N0")
                                        </div>
                                    </div>
                                }
                                <div class="text-center mt-3">
                                    <a href="@Url.Action("Dashboard", new { section = "Wallet" })" class="text-decoration-none small fw-bold">View All Transactions</a>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small text-center">No recent transactions.</p>
                            }
                        </div>
                    </div>
                </div>
                break;

            case "Bookings":
                <div class="section-header">
                    <h3 class="fw-bold">My Bookings</h3>
                    <p class="text-muted">Manage your event bookings and payments.</p>
                </div>
                <!-- Bookings -->
                <div class="glass-card">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>DATE &amp; TIME</th>
                                        <th>COST</th>
                                        <th>PAID</th>
                                        <th>STATUS</th>
                                        <th>ACTION</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var booking in Model)
                                    {
                                        <tr>
                                            <td><span class="fw-bold">#@booking.Id.Substring(0, 8)</span></td>
                                            <td>
                                                @booking.EventDate.ToString("MMM dd, yyyy")@(booking.EventEndDate.HasValue && booking.EventEndDate.Value.Date != booking.EventDate.Date ? " – " + booking.EventEndDate.Value.ToString("MMM dd, yyyy") : "")
                                                @if (!string.IsNullOrEmpty(booking.EventStartTime))
                                                {
                                                    <span class="text-muted"> · @booking.EventStartTime@(string.IsNullOrEmpty(booking.EventEndTime) ? "" : "–" + booking.EventEndTime)</span>
                                                }
                                            </td>
                                            <td>₹@booking.CustomerTotalCost.ToString("N0")</td>
                                            <td>₹@booking.AdvancePaid.ToString("N0")</td>
                                            <td>
                                                @if (booking.Status == "Requested")
                                                {<span class="badge bg-warning text-dark">Under Process</span>}
                                                else if (booking.Status == "Approved")
                                                {<span class="badge bg-info text-dark">Approved — Pay Now</span>}
                                                else if (booking.Status == "Confirmed")
                                                {<span class="badge bg-success">Confirmed</span>}
                                                else
                                                {<span class="badge bg-secondary">@booking.Status</span>}
                                            </td>
                                            <td>
                                                @if (booking.Status == "Approved" && booking.AdvancePaid < booking.CustomerTotalCost)
                                                {
                                                    var amountDue = booking.CustomerTotalCost - booking.AdvancePaid;
                                                    <a href="@Url.Action("PaymentCheckout", "Customer")"
                                                       class="btn btn-sm btn-success rounded-pill px-3">
                                                        Pay Now (₹@amountDue.ToString("N0"))
                                                    </a>
                                                }
                                                else if (booking.Status == "Confirmed" && !booking.BalancePaidOnApp && booking.BalanceAmount > 0)
                                                {
                                                    <form asp-action="PayBalance" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-3">Pay Balance ₹@booking.BalanceAmount.ToString("N0")</button>
                                                    </form>
                                                }
                                                else if (booking.Status == "Requested")
                                                {
                                                    <span class="text-muted small">Awaiting vendor</span>
                                                }
                                                @if (booking.Status == "Confirmed" && booking.EventDate < DateTime.Now)
                                                {
                                                    if (reviewedBookingIds.Contains(booking.Id))
                                                    {
                                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Reviewed</span>
                                                    }
                                                    else
                                                    {
                                                    <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" 
                                                            onclick="openFeedbackModal('@booking.Id', '@booking.VendorId', '@booking.ServiceId', '@(booking.EventDate.ToString("MMM dd, yyyy"))')">
                                                        Rate
                                                    </button>
                                                    }
                                                }
                                                <a href="@Url.Action("Invoice", "Customer", new { bookingId = booking.Id })" target="_blank"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                    <i class="bi bi-receipt me-1"></i> Invoice
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-calendar-x fs-1 text-muted mb-3 d-block"></i>
                            <p>You have no bookings yet.</p>
                            <a href="@Url.Action("Explore")" class="btn btn-primary rounded-pill">Browse Services</a>
                        </div>
                    }
                </div>
                break;

            case "ServiceRequests":
                <div class="section-header">
                    <h3 class="fw-bold">Service Requests</h3>
                    <p class="text-muted">Track your free service inquiries sent to vendors.</p>
                </div>
                <div class="glass-card">
                    @if (serviceRequestsList != null && serviceRequestsList.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr class="text-muted small">
                                        <th>VENDOR / SERVICE</th>
                                        <th>EVENT DETAILS</th>
                                        <th>STATUS</th>
                                        <th>ACTION</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in serviceRequestsList)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold">@request["VendorName"]</div>
                                                <div class="small text-muted">@request["ServiceType"]</div>
                                            </td>
                                            <td>
                                                <div class="small">
                                                    @{
                                                        var reqStart = (DateTime)request["EventDate"];
                                                        var reqEnd = request.ContainsKey("EventEndDate") && request["EventEndDate"] != null
                                                            ? (DateTime?)request["EventEndDate"] : null;
                                                        var reqDays = request.ContainsKey("DayCount") ? Convert.ToInt32(request["DayCount"]) : 1;
                                                    }
                                                    <strong>Date:</strong> @reqStart.ToString("MMM dd, yyyy")@(reqEnd.HasValue && reqEnd.Value.Date != reqStart.Date ? " – " + reqEnd.Value.ToString("MMM dd, yyyy") : "") (@reqDays day@(reqDays == 1 ? "" : "s"))<br />
                                                    @if (request.ContainsKey("EventStartTime") && request["EventStartTime"] != null)
                                                    {
                                                        <strong>Time:</strong> @request["EventStartTime"]@(request.ContainsKey("EventEndTime") && request["EventEndTime"] != null ? "–" + request["EventEndTime"] : "")<br />
                                                    }
                                                    <strong>Total:</strong> ₹@Convert.ToDecimal(request["ServiceCost"]).ToString("N0")<br />
                                                    <strong>Type:</strong> @request["EventType"]
                                                </div>
                                                @if (request.ContainsKey("PartyLocation") && !string.IsNullOrWhiteSpace(request["PartyLocation"]?.ToString()))
                                                {
                                                    <partial name="_PartyLocationDisplay" view-data='new ViewDataDictionary(ViewData) {
                                                        { "PartyLocation", request["PartyLocation"] },
                                                        { "PartyPinCode", request.ContainsKey("PartyPinCode") ? request["PartyPinCode"] : null }
                                                    }' />
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    var status = request["Status"].ToString();
                                                    var displayStatus = status == "UnderProcess" ? "Under Process" : status;
                                                    var badgeClass = (status == "Pending" || status == "UnderProcess") ? "bg-warning text-dark"
                                                        : (status == "Approved" ? "bg-success" : (status == "Paid" ? "bg-primary" : "bg-danger"));
                                                }
                                                <span class="badge @badgeClass rounded-pill px-3">@displayStatus</span>
                                            </td>
                                            <td>
                                                @if (status == "Approved")
                                                {
                                                    var payAmount = request.ContainsKey("PayAmount")
                                                        ? Convert.ToDecimal(request["PayAmount"])
                                                        : Convert.ToDecimal(request["ServiceCost"]);
                                                    <a href="@Url.Action("PaymentCheckout", "Customer")"
                                                       class="btn btn-sm btn-success rounded-pill px-3">
                                                        Pay Now (₹@payAmount.ToString("N0") incl. GST)
                                                    </a>
                                                }
                                                else if (status == "Paid")
                                                {
                                                    <span class="text-success small fw-semibold"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Awaiting vendor</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-left-dots fs-1 text-muted mb-3 d-block"></i>
                            <p>You haven't sent any service requests yet.</p>
                            <a href="@Url.Action("Explore")" class="btn btn-primary rounded-pill px-4">Find Vendors</a>
                        </div>
                    }
                </div>
                break;


            case "Wallet":
                <div class="section-header">
                    <h3 class="fw-bold">Wallet & Payments</h3>
                    <p class="text-muted">Manage your funds and view transaction history.</p>
                </div>
                <div class="row g-4">
                    <div class="col-lg-5">
                        <div class="wallet-card-new mb-4 shadow">
                            <div class="position-relative" style="z-index: 1;">
                                <div class="d-flex justify-content-between mb-4">
                                    <span class="text-white opacity-75">Available Balance</span>
                                    <i class="bi bi-wallet2 fs-4"></i>
                                </div>
                                <h1 class="display-4 fw-bold mb-4">₹@customer?.WalletBalance.ToString("N2")</h1>
                                <button class="btn btn-white bg-white text-primary rounded-pill fw-bold px-4 py-2" data-bs-toggle="modal" data-bs-target="#addMoneyModal">
                                    <i class="bi bi-plus-circle-fill me-2"></i> Add Money
                                </button>
                            </div>
                        </div>
                        
                        <div class="glass-card">
                            <h6 class="fw-bold mb-3">Add Money Quickly</h6>
                            <form asp-action="AddMoneyToWallet" method="post">
                                <div class="input-group mb-3">
                                    <span class="input-group-text">₹</span>
                                    <input type="number" name="amount" class="form-control" placeholder="Enter amount" min="100" required>
                                    <button class="btn btn-primary" type="submit">Add</button>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="this.form.amount.value=500">₹500</button>
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="this.form.amount.value=1000">₹1,000</button>
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="this.form.amount.value=5000">₹5,000</button>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <div class="glass-card h-100">
                            <h5 class="fw-bold mb-4">Transaction History</h5>
                            @if (walletTransactions != null && walletTransactions.Any())
                            {
                                <div class="list-group list-group-flush">
                                    @foreach (var txn in walletTransactions)
                                    {
                                        <div class="list-group-item px-0 py-3 border-light">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <h6 class="mb-1 fw-bold">@txn.Description</h6>
                                                    <small class="text-muted">@txn.TransactionDate.ToString("MMM dd, yyyy HH:mm")</small>
                                                </div>
                                                <div class="text-end">
                                                    <div class="fw-bold fs-5 @(txn.TransactionType == "Credit" ? "text-success" : "text-danger")">
                                                        @(txn.TransactionType == "Credit" ? "+" : "-")₹@txn.Amount.ToString("N2")
                                                    </div>
                                                    <small class="badge @(txn.TransactionType == "Credit" ? "bg-success" : "bg-danger") bg-opacity-10 @(txn.TransactionType == "Credit" ? "text-success" : "text-danger")">@txn.TransactionType</small>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <p class="text-muted">No transactions yet.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                break;

            case "Profile":
                <div class="section-header">
                    <h3 class="fw-bold">My Profile</h3>
                    <p class="text-muted">Personalize your account and contact details.</p>
                </div>
                <div class="row justify-content-center">
                    <div class="col-lg-10">
                        <div class="glass-card">
                            <form asp-action="UpdateProfile" method="post">
                                <div class="row g-4">
                                    <div class="col-md-12 text-center mb-4">
                                        <div class="user-avatar" style="width: 120px; height: 120px; font-size: 3rem;">
                                            @if (!string.IsNullOrEmpty(customer?.ProfilePicture))
                                            {
                                                <img src="@customer.ProfilePicture" id="profilePrev" />
                                            }
                                            else
                                            {
                                                <span id="charPrev">@customer?.Name?.Substring(0, 1).ToUpper()</span>
                                            }
                                        </div>
                                        <div class="mt-3">
                                            <label class="btn btn-sm btn-outline-primary rounded-pill">
                                                Change Photo
                                                <input type="file" hidden accept="image/*" onchange="previewImage(this)">
                                            </label>
                                            <input type="hidden" name="ProfilePicture" value="@customer?.ProfilePicture">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Full Name</label>
                                        <input type="text" name="Name" class="form-control rounded-3" value="@customer?.Name" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Email Address</label>
                                        <input type="email" class="form-control rounded-3 bg-light" value="@customer?.Email" readonly disabled>
                                        <small class="text-muted">Email cannot be changed.</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Phone Number</label>
                                        <input type="tel" name="Phone" class="form-control rounded-3" value="@customer?.Phone" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Secondary Phone</label>
                                        <input type="tel" name="SecondaryPhone" class="form-control rounded-3" value="@customer?.SecondaryPhone">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Date of Birth</label>
                                        <input type="date" name="DateOfBirth" class="form-control rounded-3" value="@customer?.DateOfBirth?.ToString("yyyy-MM-dd")">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small">Gender</label>
                                        <select name="Gender" class="form-select rounded-3">
                                            <option value="">Select Gender</option>
                                            <option value="Male" selected="@(customer?.Gender == "Male")">Male</option>
                                            <option value="Female" selected="@(customer?.Gender == "Female")">Female</option>
                                            <option value="Other" selected="@(customer?.Gender == "Other")">Other</option>
                                        </select>
                                    </div>
                                    <div class="col-12 mt-4 text-end">
                                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold">Save Changes</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                break;

            case "Messages":
                <div class="section-header">
                    <h3 class="fw-bold">Messages</h3>
                    <p class="text-muted">Chat with vendors about your events and bookings.</p>
                </div>
                @await Html.PartialAsync("_MessagingPanel")
                break;

            case "Addresses":
                <div class="section-header">
                    <h3 class="fw-bold">My Addresses</h3>
                    <p class="text-muted">Save your delivery and event locations.</p>
                </div>
                <div class="row g-4">
                    <div class="col-lg-8">
                        @if (addresses != null && addresses.Any())
                        {
                            <div class="row g-3">
                                @foreach (var addr in addresses)
                                {
                                    <div class="col-md-6">
                                        <div class="glass-card h-100 position-relative">
                                            @if (addr.IsDefault)
                                            {
                                                <span class="badge bg-primary rounded-pill position-absolute top-0 end-0 m-3">Default</span>
                                            }
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="bi bi-@(addr.Label == "Home" ? "house" : (addr.Label == "Office" ? "building" : "geo-alt")) fs-4 text-primary me-2"></i>
                                                <h6 class="mb-0 fw-bold">@addr.Label</h6>
                                            </div>
                                            <p class="small mb-1 fw-bold">@addr.RecipientName</p>
                                            <p class="small text-muted mb-2">@addr.AddressLine1, @addr.AddressLine2<br>@addr.City, @addr.State - @addr.PinCode</p>
                                            <p class="small mb-3"><i class="bi bi-telephone me-1"></i> @addr.Phone</p>
                                            
                                            <div class="d-flex gap-2">
                                                <form asp-action="DeleteAddress" method="post" onsubmit="return confirm('Delete this address?')">
                                                    <input type="hidden" name="addressId" value="@addr.Id">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill"><i class="bi bi-trash"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="glass-card text-center py-5">
                                <i class="bi bi-geo fs-1 text-muted mb-3 d-block"></i>
                                <p>No saved addresses yet.</p>
                            </div>
                        }
                    </div>
                    <div class="col-lg-4">
                        <div class="glass-card">
                            <h5 class="fw-bold mb-4">Add New Address</h5>
                            <form asp-action="AddAddress" method="post">
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Label (e.g. Home, Office)</label>
                                    <input type="text" name="Label" class="form-control rounded-3" placeholder="Home" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Recipient Name</label>
                                    <input type="text" name="RecipientName" class="form-control rounded-3" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Phone</label>
                                    <input type="tel" name="Phone" class="form-control rounded-3" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Address Line 1</label>
                                    <input type="text" name="AddressLine1" class="form-control rounded-3" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">City</label>
                                    <input type="text" name="City" class="form-control rounded-3 bg-light" value="Mumbai" readonly required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">PIN Code</label>
                                    <input type="text" name="PinCode" class="form-control rounded-3" placeholder="400 XXX" pattern="400[0-9]{3}" title="Please enter a valid Mumbai PIN code starting with 400" required>
                                    <div class="form-text small">Services are only available in Mumbai (PIN starting with 400).</div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-check-label small fw-bold">
                                        <input type="checkbox" name="IsDefault" class="form-check-input me-2" value="true">
                                        Set as Default Address
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Save Address</button>
                            </form>
                        </div>
                    </div>
                </div>
                break;
        }
    </main>
</div>

<!-- Modals -->
<!-- Add Money Modal -->
<div class="modal fade" id="addMoneyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Add Money to Wallet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="AddMoneyToWallet" method="post">
                <div class="modal-body p-4">
                    <div class="mb-4 text-center">
                        <i class="bi bi-wallet2 text-primary display-4"></i>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Amount to Add (₹)</label>
                        <input type="number" name="amount" id="modalAmount" class="form-control form-control-lg rounded-3 text-center fw-bold" placeholder="0.00" min="100" required>
                    </div>
                    <div class="row g-2">
                        <div class="col-4"><button type="button" class="btn btn-outline-primary btn-sm w-100" onclick="document.getElementById('modalAmount').value=500">₹500</button></div>
                        <div class="col-4"><button type="button" class="btn btn-outline-primary btn-sm w-100" onclick="document.getElementById('modalAmount').value=1000">₹1,000</button></div>
                        <div class="col-4"><button type="button" class="btn btn-outline-primary btn-sm w-100" onclick="document.getElementById('modalAmount').value=2000">₹2,000</button></div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Proceed to Pay</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Feedback Modal -->
<div class="modal fade" id="feedbackModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Share Your Experience</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small mb-4">How was the service on <span id="feedbackDate" class="fw-bold"></span>?</p>
                <form id="feedbackForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="f_bookingId" name="bookingId" />
                    <input type="hidden" id="f_vendorId" name="vendorId" />
                    <input type="hidden" id="f_serviceId" name="serviceId" />
                    <div class="text-center mb-4">
                        <div class="star-rating">
                            <i class="bi bi-star m-1 fs-2 rating-star" data-rating="1"></i>
                            <i class="bi bi-star m-1 fs-2 rating-star" data-rating="2"></i>
                            <i class="bi bi-star m-1 fs-2 rating-star" data-rating="3"></i>
                            <i class="bi bi-star m-1 fs-2 rating-star" data-rating="4"></i>
                            <i class="bi bi-star m-1 fs-2 rating-star" data-rating="5"></i>
                        </div>
                        <input type="hidden" name="rating" id="selectedRating" value="5" />
                        <div id="ratingText" class="text-primary fw-semibold mt-2">Excellent!</div>
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control rounded-3" name="comment" rows="4" placeholder="Your feedback..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold">Submit Review</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('sidebarToggle').addEventListener('click', function() {
        document.getElementById('mainSidebar').classList.toggle('collapsed');
    });

    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var prev = document.getElementById('profilePrev');
                if (prev) {
                    prev.src = e.target.result;
                } else {
                    document.getElementById('charPrev').innerHTML = '<img src="' + e.target.result + '" id="profilePrev" style="width:100%; height:100%; object-fit:cover;">';
                }
                document.querySelector('input[name="ProfilePicture"]').value = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }

    // Feedback functions (existing)
    function openFeedbackModal(bookingId, vendorId, serviceId, date) {
        document.getElementById('f_bookingId').value = bookingId;
        document.getElementById('f_vendorId').value = vendorId;
        document.getElementById('f_serviceId').value = serviceId;
        document.getElementById('feedbackDate').innerText = date;
        updateStars(5);
        new bootstrap.Modal(document.getElementById('feedbackModal')).show();
    }

    function updateStars(rating) {
        document.getElementById('selectedRating').value = rating;
        const stars = document.querySelectorAll('.rating-star');
        const labels = ["", "Poor", "Fair", "Good", "Very Good", "Excellent!"];
        stars.forEach(star => {
            const starRating = parseInt(star.getAttribute('data-rating'));
            if (starRating <= rating) {
                star.classList.replace('bi-star', 'bi-star-fill');
                star.classList.add('text-warning');
            } else {
                star.classList.replace('bi-star-fill', 'bi-star');
                star.classList.remove('text-warning');
            }
        });
        document.getElementById('ratingText').innerText = labels[rating];
    }

    document.querySelectorAll('.rating-star').forEach(star => {
        star.addEventListener('click', function() {
            updateStars(parseInt(this.getAttribute('data-rating')));
        });
    });

    document.getElementById('feedbackForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const submitBtn = this.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Submitting...';

        fetch('@Url.Action("SubmitReview", "Review")', {
            method: 'POST',
            body: new URLSearchParams(formData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert(data.message);
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Submit Review';
            }
        });
    });
</script>
