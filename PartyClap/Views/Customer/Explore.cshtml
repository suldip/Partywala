@model List<PartyClap.Models.ServiceListing>

@{
    ViewData["Title"] = "Explore Services";
}

<!-- Page Header -->
<div class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="fw-bold mb-3" style="font-size: 2rem;">Find Perfect Party Professionals</h1>
            <p class="text-muted mx-auto" style="max-width: 650px; font-size: 0.95rem;">
                Browse verified vendors, compare prices, and book your ideal party services. Pay only 20% advance to get contact details.
            </p>
        </div>

        <!-- Search Bar Row -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="search-input" class="form-control form-control-lg ps-5" 
                           placeholder="Search vendors, services, cities, or areas..."
                           style="border-radius: 8px; border: 1px solid #e5e7eb; font-size: 0.95rem;">
                </div>
            </div>
        </div>

        <!-- Location Filters -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-3">
                <select id="filter-state" class="form-select" style="border-radius: 8px; border-color: #e5e7eb;">
                    <option value="all-states">All States</option>
                    <option value="Maharashtra">Maharashtra</option>
                    <option value="Delhi">Delhi</option>
                    <option value="Karnataka">Karnataka</option>
                    <option value="Gujarat">Gujarat</option>
                    <option value="Tamil Nadu">Tamil Nadu</option>
                    <option value="Haryana">Haryana</option>
                    <option value="Telangana">Telangana</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <select id="filter-city" class="form-select" style="border-radius: 8px; border-color: #e5e7eb;">
                    <option value="all-cities">All Cities</option>
                    @if (ViewBag.Locations != null)
                    {
                        foreach (var loc in ViewBag.Locations)
                        {
                            <option value="@loc.PinCode">@loc.DisplayName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12 col-md-4">
                <div class="position-relative">
                    <i class="bi bi-geo-alt position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="location-search" class="form-control ps-5" 
                           placeholder="Quick search: city, area, pin code..."
                           style="border-radius: 8px; border-color: #e5e7eb;">
                    <div id="location-results" class="position-absolute w-100 bg-white border rounded shadow-sm mt-1" 
                         style="display: none; max-height: 200px; overflow-y: auto; z-index: 1000;">
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-2">
                <button class="btn btn-outline-secondary w-100" onclick="clearAllFilters()" style="border-radius: 8px;">
                    Clear Location
                </button>
            </div>
        </div>

        <!-- Category Pills (Quick Access) -->
        <div class="d-flex gap-2 overflow-auto pb-3 category-pills mb-2 hide-scrollbar">
            <button class="btn btn-primary category-quick-btn active" data-category="all" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; font-size: 0.9rem;">
                🎉 All Services
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="singer" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                🎵 Singers
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="magician" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                ✨ Magicians
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="chef" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                🍽️ Chefs & Caterers
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="decorator" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                🎨 Decorators
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="event-manager" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                👥 Event Managers
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="photographer" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                📸 Photographers
            </button>
            <button class="btn btn-outline-secondary category-quick-btn" data-category="casino" 
                    style="border-radius: 20px; padding: 8px 20px; white-space: nowrap; border-color: #e5e7eb; font-size: 0.9rem;">
                ✨ Casino Games
            </button>
        </div>
    </div>
</div>

<!-- Results Section -->
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h5 mb-0 fw-bold"><span id="results-count">@Model.Count</span> Party Professionals Available</h2>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <div class="btn-group" role="group">
                <button id="view-compact" class="btn btn-outline-primary btn-sm">Compact</button>
                <button id="view-detailed" class="btn btn-primary btn-sm active">Detailed</button>
            </div>
            <select id="filter-sort" class="form-select form-select-sm" style="width: auto; border-radius: 6px; border-color: #e5e7eb;">
                <option value="rating">Sort by</option>
                <option value="price-low">Price: Low to High</option>
                <option value="price-high">Price: High to Low</option>
                <option value="reviews">Most Reviews</option>
            </select>
        </div>
    </div>

    <!-- Vendor Cards -->
    <div id="vendor-list" class="row g-3">
        @if (Model != null && Model.Any())
        {
            @foreach (var service in Model)
            {
                var vendorId = service.VendorId;
                var categoryId = service.ServiceType.ToLower().Replace(" ", "-");
                var searchText = $"{service.VendorName} {service.ServiceType} {service.Description}".ToLower();
                
                // Extract City/State from Address if available
                var city = "Mumbai"; // Default
                var state = "Maharashtra"; // Default
                
                if (!string.IsNullOrEmpty(service.Address))
                {
                    var parts = service.Address.Split(',');
                    if (parts.Length > 1) city = parts[1].Trim();
                    if (parts.Length > 2) state = parts[2].Trim();
                }
                
                // Use PinCode for city filtering if dropdown uses PinCode
                var cityFilterValue = service.PinCode ?? "all-cities";
                
                // Avatar URL
                var avatarUrl = !string.IsNullOrEmpty(service.MediaUrl) 
                    ? service.MediaUrl 
                    : $"https://ui-avatars.com/api/?name={service.VendorName}&size=80&background=8B5CF6&color=fff&bold=true&font-size=0.4";
                
                // Parse Attributes JSON for rating, reviews, specialties
                var rating = "4.8";
                var reviews = "156";
                var specialties = new List<string> { "Professional", "Experienced", "Verified" };
                
                if (!string.IsNullOrEmpty(service.Attributes))
                {
                    try
                    {
                        var json = System.Text.Json.JsonDocument.Parse(service.Attributes);
                        if (json.RootElement.TryGetProperty("rating", out var ratingProp))
                            rating = ratingProp.GetDouble().ToString("0.0");
                        if (json.RootElement.TryGetProperty("reviews", out var reviewsProp))
                            reviews = reviewsProp.GetInt32().ToString();
                        if (json.RootElement.TryGetProperty("specialties", out var specialtiesProp) && specialtiesProp.ValueKind == System.Text.Json.JsonValueKind.Array)
                        {
                            specialties = new List<string>();
                            foreach (var item in specialtiesProp.EnumerateArray())
                            {
                                specialties.Add(item.GetString());
                            }
                        }
                    }
                    catch { /* Use defaults if JSON parsing fails */ }
                }
                
                <div class="col-12 vendor-card" 
                     data-vendor-id="@vendorId"
                     data-category="@categoryId"
                     data-state="@state"
                     data-city="@cityFilterValue"
                     data-search-text="@searchText">
                    
                    <div class="card border h-100 shadow-sm hover-shadow" style="border-radius: 12px; border-color: #f3f4f6 !important; transition: all 0.3s ease;">
                        <div class="card-body p-4">
                            <div class="row">
                                <!-- Left Info -->
                                <div class="col-12 col-md-9 border-end">
                                    <div class="d-flex gap-3 mb-3">
                                        <div class="flex-shrink-0">
                                            <img src="@avatarUrl" alt="@service.VendorName" class="vendor-card-img shadow-sm">
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <h3 class="h6 mb-0 fw-bold text-dark">@service.VendorName</h3>
                                                <span class="verified-badge">
                                                    <i class="bi bi-patch-check-fill"></i> Verified
                                                </span>
                                            </div>
                                            <p class="text-purple fw-semibold mb-1" style="font-size: 0.85rem;">@service.ServiceType</p>
                                            <div class="d-flex flex-wrap gap-3 text-muted mb-2" style="font-size: 0.75rem;">
                                                <span class="d-flex align-items-center gap-1"><i class="bi bi-star-fill text-warning"></i> @rating (@reviews reviews)</span>
                                                <span class="d-flex align-items-center gap-1"><i class="bi bi-geo-alt"></i> @city</span>
                                                <span class="d-flex align-items-center gap-1"><i class="bi bi-clock"></i> 8+ years</span>
                                            </div>
                                            
                                            @if (!string.IsNullOrEmpty(service.PinCode) && !string.IsNullOrEmpty(service.Address)) {
                                                <div class="mb-1" style="font-size: 0.75rem;">
                                                    <span class="text-muted"><strong>Based in:</strong> @service.Address.Split(',')[0] (@service.PinCode)</span>
                                                </div>
                                            }
                                            
                                            <div class="mb-2" style="font-size: 0.75rem;">
                                                <span class="text-muted"><strong>Services available in:</strong></span>
                                                <span class="badge badge-purple ms-1">Mumbai</span>
                                                <span class="badge badge-purple">Pune</span>
                                            </div>
                                            
                                            @if (specialties.Any()) {
                                                <div class="mb-3" style="font-size: 0.75rem;">
                                                    <span class="text-muted"><strong>Specialties:</strong></span>
                                                    @foreach (var specialty in specialties.Take(3)) {
                                                        <span class="badge badge-white ms-1">@specialty</span>
                                                    }
                                                </div>
                                            }
                                            
                                            <!-- Portfolio -->
                                            <div class="mb-3">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <span class="text-muted small fw-bold">Portfolio</span>
                                                    <a href="#" class="text-purple small text-decoration-none fw-semibold">View Profile ></a>
                                                </div>
                                                <div class="row g-2">
                                                    <div class="col-4">
                                                        <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=300&h=200&fit=crop" class="portfolio-thumb" alt="Portfolio">
                                                    </div>
                                                    <div class="col-4">
                                                        <img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=300&h=200&fit=crop" class="portfolio-thumb" alt="Portfolio">
                                                    </div>
                                                    <div class="col-4">
                                                        <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=300&h=200&fit=crop" class="portfolio-thumb" alt="Portfolio">
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Highlights -->
                                            <div class="bg-light rounded p-2 d-flex gap-4">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-shield-check text-success"></i>
                                                    <span class="small text-muted">Verified Party Professional</span>
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-calendar-check text-primary"></i>
                                                    <span class="small text-muted">50+ bookings this year</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Right Actions -->
                                <div class="col-12 col-md-3 ps-md-4 d-flex flex-column justify-content-between">
                                    <div class="text-end mb-3">
                                        <div class="h3 fw-bold text-purple mb-0">₹ @service.Cost.ToString("N0")</div>
                                        <p class="text-muted small mb-0">per hour</p>
                                        <p class="text-muted small mb-0">All-inclusive pricing</p>
                                    </div>
                                    
                                    <div class="btn-action-stack">
                                        <button class="btn btn-light-purple btn-add-to-cart" 
                                                data-vendor-id="@vendorId"
                                                data-service-id="@service.Id"
                                                data-vendor-name="@service.VendorName"
                                                data-vendor-category="@service.ServiceType"
                                                data-vendor-price="@service.Cost"
                                                data-vendor-pricing="per hour">
                                            <i class="bi bi-cart-plus"></i> Add to Cart
                                        </button>
                                        <button class="btn btn-primary" onclick="openServiceRequestDialog(@vendorId, '@service.VendorName')">
                                            <i class="bi bi-telephone"></i> Get Contact - ₹1,000
                                        </button>
                                        <button class="btn btn-outline-secondary" onclick="openServiceRequestDialog('@vendorId', '@service.Id', '@service.VendorName')">
                                            <i class="bi bi-send"></i> Request Service
                                        </button>
                                        <button class="btn btn-outline-secondary" onclick="openMessageModal('@vendorId', '@service.VendorName')">
                                            <i class="bi bi-chat"></i> Send Message
                                        </button>
                                    </div>
                                    
                                    <p class="text-muted text-center mt-2 mb-0" style="font-size: 0.65rem;">
                                        Pay only 20% advance to get contact details
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="text-center py-5" style="display: none;">
        <div class="mb-4 text-muted" style="font-size: 4rem; opacity: 0.5;">🔍</div>
        <h3 class="fw-bold mb-2">No vendors found</h3>
        <p class="text-muted mb-4">Try adjusting your search or filters</p>
        <button class="btn btn-primary" onclick="clearAllFilters()">Show All Services</button>
    </div>

    <!-- Load More -->
    @if (Model != null && Model.Any())
    {
        <div class="text-center mt-5">
            <button class="btn btn-outline-primary btn-lg px-5" style="border-radius: 8px;">Load More Vendors</button>
        </div>
    }
</div>

<!-- Service Request Modal -->
<div class="modal fade" id="service-request-modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Request Service</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form onsubmit="submitServiceRequest(event)">
                <div class="modal-body pt-4">
                    <input type="hidden" id="request-vendor-id" name="vendorId">
                    <input type="hidden" id="request-service-id" name="serviceId">
                    <div class="alert alert-light border mb-4 d-flex align-items-center gap-3">
                        <div class="bg-primary-subtle text-primary rounded-circle p-2">
                            <i class="bi bi-person-fill fs-5"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">Sending request to:</small>
                            <strong id="request-vendor-name" class="text-dark"></strong>
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted">Event Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="eventDate" required style="border-radius: 8px;" min="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small text-muted">Event Type <span class="text-danger">*</span></label>
                            <select class="form-select" name="eventType" required style="border-radius: 8px;">
                                <option value="">Select type...</option>
                                <option value="wedding">Wedding</option>
                                <option value="birthday">Birthday</option>
                                <option value="corporate">Corporate</option>
                                <option value="anniversary">Anniversary</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted">Number of Guests <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="guestCount" min="1" placeholder="e.g. 50" required style="border-radius: 8px;">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small text-muted">Additional Details</label>
                            <textarea class="form-control" name="details" rows="3" 
                                      placeholder="Tell us more about your event requirements..." style="border-radius: 8px;"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light w-100 mb-2" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                    <button type="submit" class="btn btn-primary w-100 m-0" style="border-radius: 8px;" id="submit-request-btn">
                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                        Send Request
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Message Modal -->
<div class="modal fade" id="message-modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Send Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <input type="hidden" id="msg-vendor-id">
                <div class="alert alert-light border mb-4 d-flex align-items-center gap-3">
                    <div class="bg-primary-subtle text-primary rounded-circle p-2">
                        <i class="bi bi-chat-dots-fill fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Messaging:</small>
                        <strong id="msg-vendor-name" class="text-dark"></strong>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-muted">Your Message</label>
                    <textarea class="form-control" id="msg-content" rows="4" 
                              placeholder="Type your question or requirement here..." style="border-radius: 8px;"></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light w-100 mb-2" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                <button type="button" class="btn btn-primary w-100 m-0" style="border-radius: 8px;" onclick="submitMessage()">
                    Send Message
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="~/js/customer-explore.js?v=@DateTime.Now.Ticks"></script>
<script src="~/js/cart-manager.js?v=@DateTime.Now.Ticks"></script>

<script>
// Update portfolio toggle
function togglePortfolio(vendorId) {
    const portfolio = document.getElementById(`portfolio-full-${vendorId}`);
    const icon = document.getElementById(`portfolio-icon-${vendorId}`);
    const text = document.getElementById(`portfolio-toggle-text-${vendorId}`);
    
    if (portfolio.style.display === 'none') {
        portfolio.style.display = 'block';
        icon.classList.remove('bi-chevron-down');
        icon.classList.add('bi-chevron-up');
        text.textContent = 'Hide Portfolio';
    } else {
        portfolio.style.display = 'none';
        icon.classList.remove('bi-chevron-up');
        icon.classList.add('bi-chevron-down');
        text.textContent = 'View Portfolio';
    }
}

// Messaging logic
function openMessageModal(vendorId, vendorName) {
    if (!window.isUserLoggedIn) {
        window.location.href = (window.basePath || '') + 'Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
        return;
    }
    document.getElementById('msg-vendor-id').value = vendorId;
    document.getElementById('msg-vendor-name').textContent = vendorName;
    document.getElementById('msg-content').value = "";
    new bootstrap.Modal(document.getElementById('message-modal')).show();
}

async function submitMessage() {
    const vendorId = document.getElementById('msg-vendor-id').value;
    const content = document.getElementById('msg-content').value;
    
    if (!content.trim()) {
        window.SmartPop.toast('Please enter a message.', 'error');
        return;
    }

    try {
        const response = await fetch((window.basePath || '') + 'Message/SendInitialMessage', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `vendorId=${vendorId}&content=${encodeURIComponent(content)}`
        });

        const result = await response.json();
        if (result.success) {
            window.SmartPop.toast(result.message, 'success');
            bootstrap.Modal.getInstance(document.getElementById('message-modal')).hide();
        } else {
            window.SmartPop.toast(result.message, 'error');
        }
    } catch (error) {
        window.SmartPop.toast('Failed to send message.', 'error');
    }
}
</script>

<style>
/* Responsive adjustments */
@@media (min-width: 992px) {
    .border-start-lg {
        border-left: 1px solid #f3f4f6 !important;
    }
}

.hover-shadow:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1) !important;
    border-color: #e9d5ff !important;
}

.category-quick-btn {
    transition: all 0.2s ease;
}

.category-quick-btn:hover {
    transform: translateY(-1px);
}

.category-quick-btn.active {
    background-color: var(--primary-color) !important;
    border-color: var(--primary-color) !important;
    color: white !important;
}
</style>
