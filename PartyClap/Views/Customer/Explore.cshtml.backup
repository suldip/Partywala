@model List<PartyClap.Models.ServiceListing>

@{
    ViewData["Title"] = "Explore Services";
}

<!-- Header -->
<header class="border-bottom bg-white sticky-top" style="z-index: 1000;">
    <div class="container py-3">
        <div class="d-flex justify-content-between align-items-center">
            <a href="/" class="d-flex align-items-center gap-2 text-decoration-none">
                <i class="bi bi-arrow-left fs-5"></i>
                <span class="fs-4">🎉</span>
                <span class="fw-bold fs-5 text-gradient">privateparty wala</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <a href="/cart" class="btn btn-outline-primary position-relative">
                    <i class="bi bi-cart3"></i>
                    <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
                </a>
                <a href="/account/login" class="btn btn-primary">Login</a>
            </div>
        </div>
    </div>
</header>

<!-- Page Header -->
<div class="bg-gradient-to-b py-5" style="background: linear-gradient(to bottom, #FDF2F8, #ffffff);">
    <div class="container">
        <div class="text-center mb-4">
            <h1 class="fw-bold mb-3">Find Perfect Party Professionals</h1>
            <p class="text-muted mx-auto" style="max-width: 600px;">
                Browse verified vendors, compare prices, and book your ideal party services. 
                Pay only 20% advance to get contact details.
            </p>
        </div>

        <!-- Search and Filters -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-lg-6">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="search-input" class="form-control form-control-lg ps-5" 
                           placeholder="Search vendors, services, cities, or areas...">
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <select id="filter-category" class="form-select form-select-lg">
                    <option value="all">All Categories</option>
                    <option value="singer">🎵 Singers</option>
                    <option value="chef">🍽️ Chefs & Caterers</option>
                    <option value="decorator">🎨 Decorators</option>
                    <option value="magician">✨ Magicians</option>
                    <option value="photographer">📸 Photographers</option>
                    <option value="dj">🎧 DJs</option>
                    <option value="event-manager">👥 Event Managers</option>
                </select>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <select id="filter-sort" class="form-select form-select-lg">
                    <option value="rating">Highest Rated</option>
                    <option value="price-low">Price: Low to High</option>
                    <option value="price-high">Price: High to Low</option>
                    <option value="reviews">Most Reviews</option>
                </select>
            </div>
        </div>

        <!-- Location Filters -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <select id="filter-state" class="form-select">
                    <option value="all-states">All States</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <select id="filter-city" class="form-select" disabled>
                    <option value="all-cities">All Cities</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <div class="position-relative">
                    <i class="bi bi-geo-alt position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="location-search" class="form-control ps-5" 
                           placeholder="Quick search: city, area, pin code...">
                    <div id="location-results" class="position-absolute w-100 bg-white border rounded shadow-sm mt-1" 
                         style="display: none; max-height: 200px; overflow-y: auto; z-index: 1000;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Category Quick Select -->
        <div class="d-flex gap-2 overflow-auto pb-2">
            <button class="btn btn-sm btn-outline-primary category-quick-btn active" data-category="all">
                🎉 All Services
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="singer">
                🎵 Singers
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="chef">
                🍽️ Chefs
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="decorator">
                🎨 Decorators
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="magician">
                ✨ Magicians
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="photographer">
                📸 Photographers
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="dj">
                🎧 DJs
            </button>
            <button class="btn btn-sm btn-outline-primary category-quick-btn" data-category="event-manager">
                👥 Event Managers
            </button>
        </div>
    </div>
</div>

<!-- Results Header -->
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="h4 mb-1"><span id="results-count">@Model.Count</span> Party Professionals Available</h2>
            <p class="text-muted small mb-0">Showing all verified vendors</p>
        </div>
        <div class="d-flex gap-2">
            <button id="view-compact" class="btn btn-sm btn-primary active">Compact</button>
            <button id="view-detailed" class="btn btn-sm btn-outline-primary">Detailed</button>
        </div>
    </div>

    <!-- Vendor Cards -->
    <div id="vendor-list" class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var service in Model)
            {
                var vendorId = service.VendorId;
                var categoryId = service.ServiceType.ToLower().Replace(" ", "-");
                var searchText = $"{service.VendorName} {service.ServiceType} {service.Description}".ToLower();
                
                <div class="col-12 vendor-card" 
                     data-vendor-id="@vendorId"
                     data-category="@categoryId"
                     data-state="Maharashtra"
                     data-city="Mumbai"
                     data-search-text="@searchText">
                    
                                                <h3 class="h5 mb-0 fw-bold">@service.VendorName</h3>
                                                <span class="badge bg-primary">✓ Verified</span>
                                            </div>
                                            <p class="text-primary fw-semibold mb-2">@service.ServiceType</p>
                                            
                                            <div class="d-flex flex-wrap gap-3 text-muted small">
                                                <span><i class="bi bi-star-fill text-warning"></i> 4.8 (156 reviews)</span>
                                                <span><i class="bi bi-geo-alt"></i> Mumbai, Maharashtra</span>
                                                <span><i class="bi bi-clock"></i> 8+ years</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Address -->
                                    <div class="mb-3">
                                        <p class="text-muted small mb-2">
                                            <strong>Based in:</strong> Bandra West (400050)
                                        </p>
                                        <div>
                                            <p class="text-muted small mb-1"><strong>Services available in:</strong></p>
                                            <div class="d-flex flex-wrap gap-1">
                                                <span class="badge bg-light text-dark">Mumbai</span>
                                                <span class="badge bg-light text-dark">Pune</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Specialties -->
                                    <div class="mb-3">
                                        <p class="text-muted small mb-2">Specialties:</p>
                                        <div class="d-flex flex-wrap gap-1">
                                            <span class="badge bg-light text-dark border">Bollywood</span>
                                            <span class="badge bg-light text-dark border">Classical</span>
                                            <span class="badge bg-light text-dark border">Wedding Songs</span>
                                        </div>
                                    </div>

                                    <!-- Portfolio Preview -->
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <p class="text-muted small mb-0">Portfolio:</p>
                                            <button class="btn btn-sm btn-link" id="portfolio-toggle-@vendorId" 
                                                    onclick="togglePortfolio(@vendorId)">
                                                View Portfolio
                                            </button>
                                        </div>
                                        
                                        <!-- Compact Portfolio -->
                                        <div id="portfolio-compact-@vendorId" class="row g-2">
                                            <div class="col-3">
                                                <div class="ratio ratio-1x1 rounded overflow-hidden">
                                                    <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=200&h=200&fit=crop" 
                                                         class="object-fit-cover" alt="Portfolio">
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="ratio ratio-1x1 rounded overflow-hidden">
                                                    <img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=200&h=200&fit=crop" 
                                                         class="object-fit-cover" alt="Portfolio">
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="ratio ratio-1x1 rounded overflow-hidden bg-light d-flex align-items-center justify-content-center">
                                                    <i class="bi bi-music-note-beamed fs-3 text-muted"></i>
                                                </div>
                                            </div>
                                            <div class="col-3">
                                                <div class="ratio ratio-1x1 rounded overflow-hidden bg-light d-flex align-items-center justify-content-center">
                                                    <span class="text-muted">+2</span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Full Portfolio (Hidden by default) -->
                                        <div id="portfolio-full-@vendorId" class="border rounded p-3" style="display: none;">
                                            <div class="row g-3">
                                                <div class="col-6 col-md-4">
                                                    <div class="card border-0">
                                                        <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=400&h=300&fit=crop" 
                                                             class="card-img-top rounded" alt="Performance">
                                                        <div class="card-body px-0">
                                                            <h6 class="card-title small fw-semibold">Live Performance at Wedding</h6>
                                                            <p class="card-text text-muted" style="font-size: 0.75rem;">
                                                                Performing at a wedding ceremony in Mumbai
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-6 col-md-4">
                                                    <div class="card border-0">
                                                        <img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=400&h=300&fit=crop" 
                                                             class="card-img-top rounded" alt="Studio">
                                                        <div class="card-body px-0">
                                                            <h6 class="card-title small fw-semibold">Recording Studio Session</h6>
                                                            <p class="card-text text-muted" style="font-size: 0.75rem;">
                                                                Professional recording session
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-6 col-md-4">
                                                    <div class="card border-0">
                                                        <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                                             style="height: 200px;">
                                                            <div class="text-center">
                                                                <i class="bi bi-music-note-beamed fs-1 text-primary"></i>
                                                                <p class="small text-muted mt-2">Audio Sample</p>
                                                                <button class="btn btn-sm btn-primary">
                                                                    <i class="bi bi-play-fill"></i> Play
                                                                </button>
                                                            </div>
                                                        </div>
                                                        <div class="card-body px-0">
                                                            <h6 class="card-title small fw-semibold">Bollywood Medley</h6>
                                                            <p class="card-text text-muted" style="font-size: 0.75rem;">
                                                                Popular Bollywood songs
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pricing and Actions -->
                                <div class="col-12 col-lg-4">
                                    <div class="d-flex flex-column h-100">
                                        <!-- Price -->
                                        <div class="text-end mb-3">
                                            <div class="d-flex align-items-baseline justify-content-end">
                                                <span class="h3 fw-bold text-primary mb-0">₹@service.Cost.ToString("N0")</span>
                                            </div>
                                            <p class="text-muted small mb-0">per hour</p>
                                            <p class="text-muted" style="font-size: 0.75rem;">All-inclusive pricing</p>
                                        </div>

                                        <!-- Actions -->
                                        <div class="mt-auto">
                                            <div class="d-grid gap-2">
                                                <!-- Add to Cart -->
                                                <button class="btn btn-secondary btn-add-to-cart" 
                                                        data-vendor-id="@vendorId"
                                                        data-vendor-name="@service.VendorName"
                                                        data-vendor-category="@service.ServiceType"
                                                        data-vendor-price="@service.Cost"
                                                        data-vendor-pricing="per hour"
                                                        data-vendor-image=""
                                                        data-vendor-location="Mumbai, Maharashtra">
                                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                                </button>

                                                <!-- Get Contact -->
                                                <a href="/payment" class="btn btn-primary">
                                                    <i class="bi bi-telephone"></i> Get Contact - ₹@((int)(service.Cost * 0.2))
                                                </a>

                                                <!-- Request Service -->
                                                <button class="btn btn-outline-primary" 
                                                        onclick="openServiceRequestDialog(@vendorId, '@service.VendorName')">
                                                    <i class="bi bi-send"></i> Request Service
                                                </button>

                                                <!-- Send Message -->
                                                <button class="btn btn-outline-secondary">
                                                    <i class="bi bi-chat-dots"></i> Send Message
                                                </button>
                                            </div>

                                            <p class="text-muted text-center mt-3" style="font-size: 0.75rem;">
                                                Add to cart for bulk booking or pay 20% advance to unlock contact details
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="text-center py-5" style="display: none;">
        <div class="mb-4" style="font-size: 4rem;">🔍</div>
        <h3 class="fw-bold mb-2">No vendors found</h3>
        <p class="text-muted mb-4">Try adjusting your search or category filters</p>
        <button class="btn btn-primary" onclick="clearAllFilters()">Show All Services</button>
    </div>

    <!-- Load More -->
    @if (Model != null && Model.Any())
    {
        <div class="text-center mt-5">
            <button class="btn btn-outline-primary btn-lg">Load More Vendors</button>
        </div>
    }
</div>

<!-- Service Request Modal -->
<div class="modal fade" id="service-request-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Service</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form onsubmit="submitServiceRequest(event)">
                <div class="modal-body">
                    <input type="hidden" id="request-vendor-id" name="vendorId">
                    <p class="mb-3">Send a service request to <strong id="request-vendor-name"></strong></p>
                    
                    <div class="mb-3">
                        <label class="form-label">Event Date</label>
                        <input type="date" class="form-control" name="eventDate" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Event Type</label>
                        <select class="form-select" name="eventType" required>
                            <option value="">Select event type</option>
                            <option value="wedding">Wedding</option>
                            <option value="birthday">Birthday</option>
                            <option value="corporate">Corporate Event</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Number of Guests</label>
                        <input type="number" class="form-control" name="guestCount" min="1" required>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Additional Details</label>
                        <textarea class="form-control" name="details" rows="3" 
                                  placeholder="Tell us more about your event..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Send Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="~/js/customer-explore.js"></script>
<script src="~/js/cart-manager.js"></script>

<style>
.text-gradient {
    background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.bg-gradient-primary {
    background: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
}

.category-quick-btn.active {
    background-color: var(--bs-primary);
    color: white;
    border-color: var(--bs-primary);
}

.location-result-item {
    padding: 0.75rem;
    cursor: pointer;
    border-bottom: 1px solid #e5e7eb;
}

.location-result-item:hover {
    background-color: #f3f4f6;
}

.location-result-item:last-child {
    border-bottom: none;
}

.vendor-card {
    transition: all 0.3s ease;
}

.card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1) !important;
}

.avatar-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

#view-compact.active,
#view-detailed.active {
    background-color: var(--bs-primary);
    color: white;
}
</style>
