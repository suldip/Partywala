@model PartyClap.Models.Vendor

<div class="container mt-5">
    <div class="row">
        <!-- Vendor Info -->
        <div class="col-md-4">
            <div class="card shadow p-4 text-center">
                <div class="mb-3">
                    <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px; font-size: 2rem;">
                        @Model.Name.Substring(0, 1)
                    </div>
                </div>
                <h3>@Model.Name</h3>
                <p class="text-muted">@Model.Address, @Model.PinCode</p>
                <div class="badge bg-success p-2 mb-3">Trust Score: @Model.TrustScore</div>
            </div>
        </div>

        <!-- Portfolio & Services -->
        <div class="col-md-8">
            <!-- Portfolio Section -->
            <h3 class="mb-3">Portfolio</h3>
            <div class="row mb-5">
                @if (ViewBag.Portfolio != null && ((List<PartyClap.Models.PortfolioItem>)ViewBag.Portfolio).Count > 0)
                {
                    foreach (var item in (List<PartyClap.Models.PortfolioItem>)ViewBag.Portfolio)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card h-100">
                                @if (item.MediaType == "Image")
                                {
                                    <img src="@item.MediaUrl" class="card-img-top" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="card-body bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <audio controls class="w-100">
                                            <source src="@item.MediaUrl" type="audio/mpeg">
                                        </audio>
                                    </div>
                                }
                                <div class="card-footer text-muted text-center">
                                    <small>@item.Description</small>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No portfolio items available.</p>
                }
            </div>

            <!-- Services Section -->
            <h3 class="mb-3">Services Offered</h3>
            <div class="list-group">
                @if (Model.Services != null && Model.Services.Count > 0)
                {
                    foreach (var service in Model.Services)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1">@service.ServiceType</h5>
                                <p class="mb-1">@service.Description</p>
                                <small class="text-muted">@service.Attributes</small>
                            </div>
                            <div class="text-end">
                                <h5 class="text-success">₹@service.Cost / @service.Unit</h5>
                                <a href="@Url.Action("Details", "Customer", new { serviceId = service.Id })" class="btn btn-sm btn-primary mt-1">View Details</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">No services listed.</p>
                }
            </div>
        </div>
    </div>
</div>
