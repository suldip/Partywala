@model PartyClap.Models.Vendor
@using PartyClap.Services
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model?.Name) ? "Vendor Profile" : Model.Name;
    var reviewSummary = ViewBag.ReviewSummary as PartyClap.Models.ReviewSummary;
    var vendorReviews = ViewBag.Reviews as List<PartyClap.Models.Review> ?? new List<PartyClap.Models.Review>();
    var vendorId = Model.Id;
    var vendorName = Model.Name ?? "Vendor";
    var vendorImage = Model.ProfilePicture ?? "";
    var vendorLocation = string.IsNullOrWhiteSpace(Model.Address)
        ? (Model.ServiceLocations?.FirstOrDefault() ?? "")
        : Model.Address;
    var bookableServiceCount = Model.Services?.Count(s => s.Cost >= ServicePricingRules.MinimumCost) ?? 0;
    var vendorSchedule = ViewBag.VendorSchedule as List<PartyClap.Models.VendorScheduleEntry> ?? new List<PartyClap.Models.VendorScheduleEntry>();
    var profileEventDate = ViewBag.EventDate as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/explore.css" asp-append-version="true" />
}

<div class="container py-5 vendor-profile-booking">
    <!-- Vendor Header Card -->
    <div class="card shadow-sm border-0 mb-4 overflow-hidden rounded-4">
        <div class="bg-primary-gradient p-4 text-white" style="height: 150px;"></div>
        <div class="card-body px-4 pb-4 position-relative">
            <div class="d-flex flex-column flex-md-row align-items-center align-items-md-end gap-3 profile-header-offset" style="margin-top: -80px;">
                <div class="bg-white p-2 rounded-circle shadow">
                    <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold profile-avatar" 
                         style="width: 120px; height: 120px; font-size: 3rem; background-color: #ddd;">
                        @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                        {
                            <img src="@Model.ProfilePicture" class="rounded-circle w-100 h-100 object-fit-cover" alt="@Model.Name">
                        }
                        else
                        {
                            <span>@(string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name.Substring(0, 1))</span>
                        }
                    </div>
                </div>
                <div class="text-center text-md-start mb-3 mb-md-0 flex-grow-1">
                    <h1 class="fw-bold mb-1">@Model.Name</h1>
                    <p class="text-muted mb-2"><i class="bi bi-geo-alt-fill text-primary"></i> @Model.Address, @Model.PinCode</p>
                    <div class="d-flex gap-2 justify-content-center justify-content-md-start flex-wrap">
                         <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill">
                            <i class="bi bi-shield-check me-1"></i> Trust Score: @Model.TrustScore
                        </span>
                        @if (reviewSummary != null && reviewSummary.ReviewCount > 0)
                        {
                            <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle px-3 py-2 rounded-pill">
                                <i class="bi bi-star-fill me-1"></i> @reviewSummary.AverageRating.ToString("0.0") / 5 (@reviewSummary.ReviewCount reviews)
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-light text-muted border px-3 py-2 rounded-pill">
                                <i class="bi bi-star me-1"></i> No reviews yet
                            </span>
                        }
                        @if (Model.IsRegistered)
                        {
                             <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill">
                                <i class="bi bi-check-circle-fill me-1"></i> Verified Vendor
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Content -->
        <div class="col-lg-8">
            
            <!-- About / Services -->
            <div id="services-section" class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Services Offered</h4>
                    @if (Model.Services != null && Model.Services.Count > 0)
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var service in Model.Services)
                            {
                                <div class="p-3 border rounded-3 bg-light-subtle hover-shadow transition-all">
                                    <div class="d-flex justify-content-between align-items-start service-row-inner">
                                        <div>
                                            <h5 class="fw-bold text-primary mb-1">@service.ServiceType</h5>
                                            <p class="mb-2 text-muted">@service.Description</p>
                                            @if (!string.IsNullOrEmpty(service.Attributes))
                                            {
                                                try 
                                                {
                                                    var atts = System.Text.Json.JsonDocument.Parse(service.Attributes);
                                                    if (atts.RootElement.TryGetProperty("specialties", out var specs) && specs.ValueKind == System.Text.Json.JsonValueKind.Array)
                                                    {
                                                        <div class="mt-2">
                                                            @foreach (var spec in specs.EnumerateArray())
                                                            {
                                                                <span class="badge bg-light text-dark border me-1">@spec.GetString()</span>
                                                            }
                                                        </div>
                                                    }
                                                }
                                                catch
                                                {
                                                    <small class="text-muted d-block mb-1"><i class="bi bi-info-circle me-1"></i> @service.Attributes</small>
                                                }
                                            }
                                        </div>
                                        <div class="text-end">
                                             <div class="h5 fw-bold text-dark mb-0">₹@service.Cost.ToString("N0")</div>
                                             <small class="text-muted">per @service.Unit</small>
                                        </div>
                                    </div>
                                    <div class="mt-3 pt-3 border-top">
                                        <div class="d-flex flex-wrap gap-2 justify-content-end align-items-center service-card-actions">
                                            @if (service.Cost >= ServicePricingRules.MinimumCost)
                                            {
                                                <button type="button" class="btn btn-outline-primary btn-add-to-cart"
                                                        data-vendor-id="@vendorId"
                                                        data-service-id="@service.Id"
                                                        data-vendor-name="@vendorName"
                                                        data-vendor-category="@service.ServiceType"
                                                        data-vendor-price="@service.Cost"
                                                        data-vendor-pricing="per @service.Unit"
                                                        data-vendor-image="@vendorImage"
                                                        data-vendor-location="@vendorLocation">
                                                    <i class="bi bi-cart-plus me-1"></i> Add to Cart
                                                </button>
                                                <button type="button" class="btn btn-primary btn-book-service"
                                                        data-vendor-id="@vendorId"
                                                        data-service-id="@service.Id"
                                                        data-vendor-name="@vendorName"
                                                        data-vendor-category="@service.ServiceType"
                                                        data-vendor-price="@service.Cost"
                                                        data-vendor-pricing="per @service.Unit"
                                                        data-vendor-image="@vendorImage"
                                                        data-vendor-location="@vendorLocation">
                                                    <i class="bi bi-calendar-check me-1"></i> Book
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning-emphasis border">
                                                    Price on request
                                                </span>
                                            }
                                            <button type="button" class="btn btn-outline-secondary btn-request-service"
                                                    title="Request a quote for your selected date"
                                                    data-vendor-id="@vendorId"
                                                    data-service-id="@service.Id"
                                                    data-vendor-name="@vendorName"
                                                    data-service-cost="@service.Cost"
                                                    data-weekend-cost="@(service.WeekendCost?.ToString() ?? "")">
                                                <i class="bi bi-send me-1"></i> Request Service
                                            </button>
                                        </div>
                                        @if (service.Cost >= ServicePricingRules.MinimumCost)
                                        {
                                            <p class="text-muted text-end mt-2 mb-0 small">
                                                Pay only 20% advance to confirm your booking
                                            </p>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-basket display-4 d-block mb-2"></i>
                            No services listed yet.
                        </div>
                    }
                </div>
            </div>

            <!-- Customer Reviews -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-bold m-0">Customer Reviews</h4>
                        @if (reviewSummary != null && reviewSummary.ReviewCount > 0)
                        {
                            <span class="badge bg-light text-dark border px-3 py-2">
                                @reviewSummary.AverageRating.ToString("0.0") ★ · @reviewSummary.ReviewCount total
                            </span>
                        }
                    </div>

                    @if (vendorReviews.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var review in vendorReviews)
                            {
                                <div class="border rounded-3 p-3 bg-light-subtle">
                                    <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                        <div>
                                            <div class="fw-semibold">@review.CustomerName</div>
                                            @if (!string.IsNullOrWhiteSpace(review.ServiceName))
                                            {
                                                <small class="text-muted">@review.ServiceName</small>
                                            }
                                        </div>
                                        <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <div class="mb-2 text-warning">
                                        @for (var star = 1; star <= 5; star++)
                                        {
                                            <i class="bi @(star <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                        }
                                        <span class="text-dark ms-1 small fw-semibold">@review.Rating/5</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                                    {
                                        <p class="mb-0 text-muted">@review.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-chat-square-quote display-6 d-block mb-2"></i>
                            No customer reviews yet. Book this vendor and share your experience after the event.
                        </div>
                    }
                </div>
            </div>

            <!-- Portfolio Header -->
             <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold m-0">Portfolio</h4>
                <span class="badge bg-light text-dark border">
                    @((ViewBag.Portfolio as List<PartyClap.Models.PortfolioItem>)?.Count ?? 0) Items
                </span>
            </div>

            <!-- Portfolio Grid -->
             <div class="row g-3">
                @if (ViewBag.Portfolio != null && ((List<PartyClap.Models.PortfolioItem>)ViewBag.Portfolio).Count > 0)
                {
                    foreach (var item in (List<PartyClap.Models.PortfolioItem>)ViewBag.Portfolio)
                    {
                        <div class="col-md-4 col-6">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden rounded-3 position-relative group-hover-zoom">
                                @if (item.MediaType == "Image")
                                {
                                    var portfolioImages = (ViewBag.Portfolio as List<PartyClap.Models.PortfolioItem>)?.Where(i => i.MediaType == "Image").ToList();
                                    var imgIndex = portfolioImages?.IndexOf(item) ?? 0;
                                    
                                    <a href="javascript:void(0)" class="portfolio-lightbox-trigger" data-lightbox-index="@imgIndex">
                                        <img src="@item.MediaUrl" class="w-100 h-100 object-fit-cover portfolio-gallery-item" style="min-height: 200px; cursor: zoom-in;" alt="@item.Description" data-caption="@item.Description">
                                        <div class="position-absolute bottom-0 start-0 w-100 p-2 bg-gradient-dark text-white opacity-0 hover-opacity-100 transition-all">
                                            <small class="d-block text-truncate">@item.Description</small>
                                        </div>
                                    </a>
                                }
                                else if (item.MediaType == "Video")
                                {
                                     <div class="position-relative bg-black h-100 d-flex align-items-center justify-content-center" style="min-height: 200px;">
                                        <video src="@item.MediaUrl" class="w-100 h-100 object-fit-cover" controls></video>
                                    </div>
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center h-100 p-3" style="min-height: 200px;">
                                        <audio controls class="w-100">
                                            <source src="@item.MediaUrl" type="audio/mpeg">
                                            Your browser does not support the audio element.
                                        </audio>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-light text-center border-0 py-5">
                            <i class="bi bi-images display-6 text-muted mb-3 d-block"></i>
                            <p class="text-muted mb-0">No portfolio items uploaded yet.</p>
                        </div>
                    </div>
                }
            </div>

        </div>

        <!-- Sidebar -->
        <div class="col-lg-4 profile-sidebar-col order-first order-lg-last">
             <div class="sticky-top" style="top: 100px;">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-3">Service Locations</h5>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @if (Model.ServiceLocations != null && Model.ServiceLocations.Any())
                        {
                            foreach (var loc in Model.ServiceLocations)
                            {
                                <span class="badge bg-light text-dark border">@loc</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted small">Available in @Model.Address area</span>
                        }
                    </div>

                    <hr class="my-4">

                    <h5 class="fw-bold mb-3">Pick Party Date</h5>
                    <p class="small text-muted">Green = available · Red = booked. Select a green date, then book below.</p>
                    <partial name="_VendorAvailabilityCalendar" view-data='@(new ViewDataDictionary(ViewData) {
                        { "CalendarVendorId", vendorId },
                        { "CalendarInitialDate", profileEventDate },
                        { "CalendarSchedule", vendorSchedule }
                    })' />

                    <hr class="my-4">
                    
                    <h5 class="fw-bold mb-3">Contact</h5>
                     <div class="d-grid gap-2">
                         <button type="button" class="btn btn-primary" id="btn-book-vendor-now"
                                 @(bookableServiceCount == 0 ? "disabled=\"disabled\" title=\"No bookable services — send a message or request a quote\"" : "")>
                            <i class="bi bi-calendar-plus me-2"></i> Book Now
                         </button>
                         <button type="button" class="btn btn-outline-primary btn-send-message" id="btn-send-message" disabled
                                 title="Use Book or Add to Cart to contact this vendor"
                                 data-vendor-id="@Model.Id"
                                 data-vendor-name="@Model.Name">
                            <i class="bi bi-chat-dots me-2"></i> Send Message
                         </button>
                         <p class="small text-muted text-center mt-2 mb-0">Opens a secure chat — your message appears in your dashboard inbox.</p>
                     </div>
                </div>
            </div>
        </div>
    </div>

    <div class="vendor-profile-mobile-cta d-lg-none">
        <button type="button" class="btn btn-primary" id="btn-book-vendor-mobile"
                @(bookableServiceCount == 0 ? "disabled=\"disabled\"" : "")>
            <i class="bi bi-calendar-plus me-1"></i> Book Now
        </button>
        <a href="#services-section" class="btn btn-outline-primary">
            <i class="bi bi-list-ul me-1"></i> Services
        </a>
    </div>
</div>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content bg-transparent border-0 shadow-none">
      <div class="modal-body p-0 position-relative text-center">
        <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3 z-3" data-bs-dismiss="modal" aria-label="Close"></button>
        
        <div class="lightbox-navigation">
            <button type="button" class="nav-btn prev-btn" data-lightbox-step="-1">
                <i class="bi bi-chevron-left"></i>
            </button>
            
            <div class="image-container">
                <img id="lightboxImage" src="" class="img-fluid rounded shadow-lg animate__animated animate__fadeIn" style="max-height: 85vh;" alt="Portfolio Item">
                <div class="caption-overlay">
                    <p id="lightboxCaption" class="text-white m-0 fw-semibold"></p>
                    <small id="lightboxCounter" class="text-white-50"></small>
                </div>
            </div>

            <button type="button" class="nav-btn next-btn" data-lightbox-step="1">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
      </div>
    </div>
  </div>
</div>


<partial name="_ServiceRequestModal" />

<!-- Message Modal -->
<div class="modal fade" id="message-modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Send Message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-4">
                <input type="hidden" id="msg-vendor-id">
                <div class="alert alert-light border mb-4 d-flex align-items-center gap-3">
                    <div class="bg-primary-subtle text-primary rounded-circle p-2">
                        <i class="bi bi-chat-dots-fill fs-5"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block">Messaging:</small>
                        <strong id="msg-vendor-name" class="text-dark"></strong>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-muted">Your Message</label>
                    <textarea class="form-control" id="msg-content" rows="4" 
                              placeholder="Type your question or requirement here..." style="border-radius: 8px;"></textarea>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light w-100 mb-2" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                <button type="button" class="btn btn-primary w-100 m-0" id="btn-submit-message" style="border-radius: 8px;">
                    Send Message
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/vendor-availability-calendar.js" asp-append-version="true"></script>
    <script src="~/js/customer-explore.js?v=@DateTime.Now.Ticks"></script>
    <script src="~/js/messaging.js" asp-append-version="true"></script>

    <script>
        let currentImgIndex = 0;
        let galleryImages = [];

        function openLightbox(index) {
            galleryImages = Array.from(document.querySelectorAll('.portfolio-gallery-item')).map(img => ({
                src: img.src,
                caption: img.getAttribute('data-caption')
            }));
            
            currentImgIndex = index;
            updateLightbox();
            
            const modal = new bootstrap.Modal(document.getElementById('lightboxModal'));
            modal.show();
        }

        function updateLightbox() {
            const img = galleryImages[currentImgIndex];
            const imageElement = document.getElementById('lightboxImage');
            const captionElement = document.getElementById('lightboxCaption');
            const counterElement = document.getElementById('lightboxCounter');
            
            imageElement.src = img.src;
            captionElement.textContent = img.caption || 'Portfolio Item';
            counterElement.textContent = `${currentImgIndex + 1} / ${galleryImages.length}`;

            // Handle nav visibility
            document.querySelector('.prev-btn').style.visibility = (currentImgIndex > 0) ? 'visible' : 'hidden';
            document.querySelector('.next-btn').style.visibility = (currentImgIndex < galleryImages.length - 1) ? 'visible' : 'hidden';
        }

        function changeImage(step) {
            currentImgIndex += step;
            if (currentImgIndex < 0) currentImgIndex = 0;
            if (currentImgIndex >= galleryImages.length) currentImgIndex = galleryImages.length - 1;
            
            const imgElement = document.getElementById('lightboxImage');
            imgElement.classList.remove('animate__fadeIn');
            void imgElement.offsetWidth; // Trigger reflow
            imgElement.classList.add('animate__fadeIn');
            
            updateLightbox();
        }

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            const modal = document.getElementById('lightboxModal');
            if (modal.classList.contains('show')) {
                if (e.key === "ArrowLeft") changeImage(-1);
                if (e.key === "ArrowRight") changeImage(1);
                if (e.key === "Escape") bootstrap.Modal.getInstance(modal).hide();
            }
        });

        function vendorDataFromButton(btn) {
            return {
                id: btn.dataset.vendorId,
                serviceId: btn.dataset.serviceId,
                name: btn.dataset.vendorName,
                category: btn.dataset.vendorCategory,
                basePrice: parseFloat(btn.dataset.vendorPrice),
                pricingModel: btn.dataset.vendorPricing,
                image: btn.dataset.vendorImage,
                location: btn.dataset.vendorLocation
            };
        }

        function bookServiceNow(btn) {
            if (!window.isUserLoggedIn) {
                window.location.href = (window.basePath || '') + 'Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
                return;
            }

            const vendorData = vendorDataFromButton(btn);
            if (cartManager.isInCart(vendorData.id, vendorData.serviceId)) {
                window.location.href = (window.basePath || '') + 'Customer/ViewCart';
                return;
            }

            const result = cartManager.addToCart(vendorData);
            if (result && typeof result.then === 'function') {
                result.then(function (data) {
                    if (data && data.success) {
                        window.location.href = (window.basePath || '') + 'Customer/ViewCart';
                    }
                });
            }
        }

        function bookVendorNow() {
            if (!window.isUserLoggedIn) {
                window.location.href = (window.basePath || '') + 'Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
                return;
            }

            const bookable = document.querySelectorAll('button.btn-add-to-cart[data-service-id]');
            if (bookable.length === 0) {
                window.SmartPop.toast('This vendor has no bookable services yet. Send a message or request a quote.', 'warning');
                return;
            }

            if (bookable.length === 1) {
                bookable[0].click();
                setTimeout(function () {
                    window.location.href = (window.basePath || '') + 'Customer/ViewCart';
                }, 1000);
                return;
            }

            const section = document.getElementById('services-section');
            section.scrollIntoView({ behavior: 'smooth' });
            section.classList.add('book-highlight');
            setTimeout(function () { section.classList.remove('book-highlight'); }, 3000);
            window.SmartPop.toast('Choose a service below and add it to your cart.', 'info');
        }

        window.bookVendorNow = bookVendorNow;
        window.bookServiceNow = bookServiceNow;

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('btn-book-vendor-now')?.addEventListener('click', bookVendorNow);
            document.getElementById('btn-book-vendor-mobile')?.addEventListener('click', bookVendorNow);

            document.querySelectorAll('.btn-book-service').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    bookServiceNow(this);
                });
            });

            document.querySelectorAll('.btn-request-service').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    openServiceRequestDialog(
                        this.dataset.vendorId,
                        this.dataset.serviceId,
                        this.dataset.vendorName,
                        this);
                });
            });

            document.querySelectorAll('.portfolio-lightbox-trigger').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    openLightbox(parseInt(this.dataset.lightboxIndex, 10));
                });
            });

            document.querySelectorAll('[data-lightbox-step]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    changeImage(parseInt(this.dataset.lightboxStep, 10));
                });
            });

        });
    </script>
}

<style>
    .bg-primary-gradient {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    }
    .hover-shadow:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    #services-section.book-highlight {
        box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.35);
        transition: box-shadow 0.3s ease;
    }
    .service-card-actions .btn {
        min-width: 8.5rem;
    }
    .transition-all {
        transition: all 0.3s ease;
    }
    .bg-gradient-dark {
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
    }
    .hover-opacity-100:hover {
        opacity: 1 !important;
    }

    /* Lightbox Enhanced Styles */
    .lightbox-navigation {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        min-height: 90vh;
    }
    .nav-btn {
