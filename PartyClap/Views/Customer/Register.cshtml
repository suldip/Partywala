@model PartyClap.Models.Customer

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0">Join PartyClap</h3>
                    <p class="mb-0 text-white-50">Create your customer account</p>
                </div>
                <div class="card-body p-5">
                    <!-- Google Login Simulation -->
                    <div class="d-grid mb-4">
                        <button type="button" class="btn btn-outline-dark btn-lg d-flex align-items-center justify-content-center gap-2" onclick="simulateGoogleLogin()">
                            <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.05H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.05l3.66 2.84c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
                            </svg>
                            Sign up with Google
                        </button>
                    </div>

                    <div class="position-relative mb-4">
                        <hr>
                        <div class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted">or</div>
                    </div>

                    <form asp-action="Register" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" placeholder="Your Name" required />
                            <label asp-for="Name">Full Name</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required />
                            <label asp-for="Email">Email Address</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Phone" type="tel" class="form-control" placeholder="Phone Number" required />
                            <label asp-for="Phone">Phone Number</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Password" required />
                            <label asp-for="Password">Password</label>
                        </div>
                        
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Create Account</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small"><a href="#">Have an account? Go to Login</a></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Listen for the message from the popup
    window.addEventListener("message", function(event) {
        if (event.data === "google-login-success") {
            window.location.href = "/PartyClap/Customer/Explore";
        }
    }, false);

    function simulateGoogleLogin() {
        var w = 500;
        var h = 600;
        var left = (screen.width / 2) - (w / 2);
        var top = (screen.height / 2) - (h / 2);
        
        var popup = window.open("", "Google Login", "width=" + w + ",height=" + h + ",top=" + top + ",left=" + left);
        
        if (popup) {
            var doc = popup.document;
            
            // Set title
            doc.title = "Google Sign In";
            
            // Create and append style
            var style = doc.createElement("style");
            style.textContent = "body { font-family: sans-serif; text-align: center; padding: 50px; }";
            if (doc.head) {
                doc.head.appendChild(style);
            } else {
                doc.body.appendChild(style);
            }
            
            // Add Title
            var h2 = doc.createElement("h2");
            h2.textContent = "Google Sign In Simulation";
            doc.body.appendChild(h2);
            
            // Add Description
            var p = doc.createElement("p");
            p.textContent = "Choose an account to continue to PartyClap";
            doc.body.appendChild(p);
            
            // Add Button
            var btn = doc.createElement("button");
            btn.textContent = "Continue as User";
            btn.style.padding = "10px 20px";
            btn.style.fontSize = "16px";
            btn.style.cursor = "pointer";
            btn.style.background = "#4285F4";
            btn.style.color = "white";
            btn.style.border = "none";
            btn.style.borderRadius = "4px";
            btn.style.marginTop = "20px";
            
            btn.onclick = function() {
                if (window.opener) {
                    window.opener.postMessage("google-login-success", "*");
                }
                window.close();
            };
            
            doc.body.appendChild(btn);
        }
    }
</script>
