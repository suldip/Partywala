<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS hosting for PartyClap (.NET 8)

  Deploy the FULL "dotnet publish -c Release" output folder (includes PartyClap.dll).
  Install: ASP.NET Core 8.0 Hosting Bundle, then run iisreset.

  After deploy:
  1. Create folder: logs (next to PartyClap.dll)
  2. Grant IIS App Pool identity Modify permission on the site folder + logs
  3. Set production MySQL connection (IIS -> Configuration Editor or web.config env var below)
  4. If startup fails, read logs\stdout_*.log for the exact error
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <remove name="X-AspNet-Version" />
        <remove name="X-AspNetMvc-Version" />
        <remove name="Server" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
      </customHeaders>
    </httpProtocol>
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet" arguments=".\PartyClap.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        <!-- Uncomment and set your production MySQL connection on the server:
        <environmentVariable name="ConnectionStrings__DefaultConnection" value="server=127.0.0.1;port=3306;database=partyclapdb;user=YOUR_USER;password=YOUR_PASSWORD;" />
        -->
      </environmentVariables>
    </aspNetCore>
  </system.webServer>
</configuration>
