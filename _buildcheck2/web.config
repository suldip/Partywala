<?xml version="1.0" encoding="utf-8"?>
<!--
  Security hardening for IIS / IIS Express hosting.
  On publish, the .NET SDK injects the aspNetCore handler into this file while
  preserving the settings below, which strip server-identifying response headers.
-->
<configuration>
  <system.webServer>
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <remove name="Server" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
